---
import { navItems, siteConfig } from "../data/site";
const year = new Date().getFullYear();
---

<footer class="border-t border-white/10 bg-black/60">
  <div class="section-shell py-12">
    <div class="grid gap-8 lg:grid-cols-[1.15fr_0.85fr_0.85fr]">
      <div>
        <div class="flex items-center gap-3">
          <img src="/assets/brand/logo-clear.png" alt="" class="h-12 w-12 rounded-md bg-black object-contain" />
          <div>
            <p class="font-display text-2xl font-black uppercase leading-none text-white">{siteConfig.name}</p>
            <p class="mt-1 text-sm text-steel">{siteConfig.domain}</p>
          </div>
        </div>
        <p class="mt-5 max-w-xl text-sm leading-6 text-steel">{siteConfig.tagline}</p>
      </div>

      <div>
        <p class="eyebrow">Navigation</p>
        <div class="mt-4 grid grid-cols-2 gap-2">
          {navItems.map((item) => <a class="text-sm text-haze transition hover:text-neon-cyan" href={item.href}>{item.label}</a>)}
          <a class="text-sm text-haze transition hover:text-neon-cyan" href="/privacy-policy">Privacy Policy</a>
        </div>
      </div>

      <div>
        <p class="eyebrow">Connect</p>
        <div class="mt-4 flex flex-wrap gap-2">
          {
            siteConfig.socials.map((social) => (
              <a
                class="rounded-md border border-white/10 px-3 py-2 text-sm font-semibold text-haze transition hover:border-neon-cyan/60 hover:text-white"
                href={social.href}
                target={social.href.startsWith("http") ? "_blank" : undefined}
                rel={social.href.startsWith("http") ? "noreferrer" : undefined}
              >
                {social.label}
              </a>
            ))
          }
        </div>
      </div>
    </div>

    <div class="mt-10 flex flex-col gap-3 border-t border-white/10 pt-6 text-xs text-steel sm:flex-row sm:items-center sm:justify-between">
      <p>&copy; {year} {siteConfig.name}. All rights reserved.</p>
      <p>Built for Cloudflare Pages with future Workers, D1 and R2 integration.</p>
    </div>
  </div>
</footer>
