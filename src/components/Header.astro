---
import { navItems, siteConfig } from "../data/site";

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const loginActive = pathname === "/artist-dashboard";
const adminActive = pathname === "/admin";

function normalizeHref(href: string) {
  return href.replace(/\/$/, "") || "/";
}
---

<header class="sticky top-0 z-40 border-b border-white/10 bg-obsidian/82 backdrop-blur-xl">
  <div class="section-shell flex flex-col gap-3 py-3 sm:flex-row sm:items-center sm:justify-between">
    <a href="/" class="group flex items-center gap-3" aria-label={`${siteConfig.name} home`}>
      <span class="grid h-11 w-11 place-items-center overflow-hidden rounded-md border border-white/10 bg-black">
        <img src={siteConfig.logo} alt="" class="h-10 w-10 object-cover transition duration-300 group-hover:scale-105" />
      </span>
      <span class="leading-none">
        <span class="block font-display text-lg font-black uppercase text-white">The MasterBeat</span>
        <span class="block font-mono text-[0.65rem] font-semibold uppercase tracking-[0.28em] text-steel">Project</span>
      </span>
    </a>

    <nav aria-label="Primary navigation" class="flex flex-wrap items-center gap-1.5">
      {
        navItems.map((item) => {
          const itemPath = normalizeHref(item.href);
          const active = itemPath === "/" ? pathname === "/" : pathname === itemPath;
          return (
            <a
              href={item.href}
              class:list={[
                "rounded-md px-3 py-2 text-xs font-bold uppercase tracking-[0.12em] transition duration-200",
                active ? "bg-white text-black" : "text-haze hover:bg-white/10 hover:text-white"
              ]}
            >
              {item.label}
            </a>
          );
        })
      }
      <span class="contents" data-auth-nav>
        <a
          href="/artist-dashboard/"
          data-nav-login
          class:list={[
            "rounded-md px-3 py-2 text-xs font-bold uppercase tracking-[0.12em] transition duration-200",
            loginActive ? "bg-white text-black" : "text-haze hover:bg-white/10 hover:text-white"
          ]}
        >
          Login
        </a>
        <a
          href="/artist-dashboard/"
          data-nav-dashboard
          hidden
          class:list={[
            "rounded-md px-3 py-2 text-xs font-bold uppercase tracking-[0.12em] transition duration-200",
            loginActive ? "bg-white text-black" : "text-haze hover:bg-white/10 hover:text-white"
          ]}
        >
          Artist Dashboard
        </a>
        <a
          href="/admin/"
          data-nav-admin
          hidden
          class:list={[
            "rounded-md px-3 py-2 text-xs font-bold uppercase tracking-[0.12em] transition duration-200",
            adminActive ? "bg-white text-black" : "text-haze hover:bg-white/10 hover:text-white"
          ]}
        >
          Admin
        </a>
      </span>
    </nav>
  </div>
</header>

<script>
  const authNav = document.querySelector("[data-auth-nav]");
  const loginLink = authNav?.querySelector("[data-nav-login]");
  const dashboardLink = authNav?.querySelector("[data-nav-dashboard]");
  const adminLink = authNav?.querySelector("[data-nav-admin]");

  function applyAuthNav(data: unknown) {
    const sessionData = data as { authenticated?: boolean; session?: { role?: string }; role?: string };
    const authenticated = Boolean(sessionData?.authenticated || sessionData?.role);
    const role = sessionData?.session?.role || sessionData?.role;
    if (loginLink instanceof HTMLElement) loginLink.hidden = authenticated;
    if (dashboardLink instanceof HTMLElement) dashboardLink.hidden = !authenticated;
    if (adminLink instanceof HTMLElement) adminLink.hidden = !(authenticated && role === "admin");
  }

  window.addEventListener("mbp-auth-changed", (event) => applyAuthNav((event as CustomEvent).detail || {}));

  fetch("/api/auth/me", { cache: "no-store", headers: { "cache-control": "no-cache" } })
    .then((response) => response.json())
    .then(applyAuthNav)
    .catch(() => {});
</script>
