<section class="hidden py-20" data-live-catalog>
  <div class="section-shell">
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="eyebrow">Live catalogue</p>
        <h2 class="mt-3 font-display text-3xl font-black uppercase leading-none text-white sm:text-5xl">Database releases</h2>
        <p class="mt-4 max-w-3xl text-base leading-7 text-steel">Release data loaded from Cloudflare D1, including playable platform links.</p>
      </div>
    </div>
    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3" data-live-releases></div>
  </div>
</section>

<script>
  // @ts-nocheck
  const liveCatalog = document.querySelector("[data-live-catalog]");
  const liveReleases = document.querySelector("[data-live-releases]");
  const staticReleases = document.querySelector("[data-static-releases]");

  const escapeHtml = (value) =>
    String(value ?? "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#39;");

  async function loadLiveCatalog() {
    if (!liveCatalog || !liveReleases) return;
    try {
      const response = await fetch("/api/catalog");
      const data = await response.json();
      if (!data.ok || !Array.isArray(data.releases) || data.releases.length === 0) return;

      liveCatalog.classList.remove("hidden");
      staticReleases?.classList.add("hidden");
      liveReleases.innerHTML = data.releases
        .map(
          (release) => `
            <article class="clip-diagonal border border-white/10 bg-carbon/80 p-5">
              ${release.artwork_url ? `<img class="mb-5 aspect-square w-full rounded-md border border-white/10 object-cover" src="${escapeHtml(release.artwork_url)}" alt="${escapeHtml(release.title)} artwork" loading="lazy" />` : ""}
              <p class="font-mono text-xs font-bold uppercase tracking-[0.16em] text-neon-cyan">${escapeHtml(release.catalog_number)} | ${escapeHtml(release.status)}</p>
              <h3 class="mt-3 font-display text-3xl font-black uppercase leading-none text-white">${escapeHtml(release.title)}</h3>
              <p class="mt-2 text-sm font-semibold text-haze">${escapeHtml(release.artist_display)}</p>
              <p class="mt-4 text-sm leading-6 text-steel">${escapeHtml(release.description || release.genre || "The MasterBeat Project release.")}</p>
              <div class="mt-5 flex flex-wrap gap-2">
                ${(release.platform_links || [])
                  .map((link) => `<a class="rounded-md border border-white/10 px-3 py-2 text-xs font-bold uppercase tracking-[0.1em] text-haze hover:border-neon-cyan hover:text-white" href="${escapeHtml(link.url)}" target="_blank" rel="noreferrer">${escapeHtml(link.label)}</a>`)
                  .join("")}
              </div>
            </article>
          `
        )
        .join("");
    } catch {
      // Static fallback remains visible when the D1 catalogue is not configured yet.
    }
  }

  loadLiveCatalog();
</script>
