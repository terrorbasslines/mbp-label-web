---
interface Props {
  label?: string;
  catalogueHref?: string;
  presaveHeading?: string;
  fallbackMark?: string;
  releaseCopy?: string;
}

const {
  label = "mbp",
  catalogueHref = "/releases/",
  presaveHeading = "Open MBP pre-saves",
  fallbackMark = "MBP",
  releaseCopy = "Choose your preferred streaming service or open the full MBP release page."
} = Astro.props;
const catalogEndpoint = `/api/catalog?view=home&label=${encodeURIComponent(label)}`;
---

<div class="hidden" data-home-latest-live data-home-catalog-endpoint={catalogEndpoint} data-home-fallback-mark={fallbackMark} data-home-release-copy={releaseCopy}>
  <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4" data-home-published-grid></div>
  <div class="mt-16 hidden" data-home-presave-section>
    <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="eyebrow">Upcoming pre-saves</p>
        <h3 class="mt-2 font-display text-3xl font-black uppercase leading-none text-white sm:text-4xl">{presaveHeading}</h3>
      </div>
      <a class="inline-flex min-h-10 items-center justify-center rounded-md border border-white/10 px-4 py-2 text-xs font-black uppercase tracking-[0.14em] text-haze transition hover:border-neon-cyan hover:text-white" href={catalogueHref}>
        View catalogue
      </a>
    </div>
    <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-4" data-home-presave-grid></div>
  </div>
</div>

<script>
  // @ts-nocheck
  const homeLatestLive = document.querySelector("[data-home-latest-live]");
  const homePublishedGrid = document.querySelector("[data-home-published-grid]");
  const homePresaveSection = document.querySelector("[data-home-presave-section]");
  const homePresaveGrid = document.querySelector("[data-home-presave-grid]");
  const homeStaticReleases = document.querySelector("[data-home-static-releases]");
  const homeCountCards = [...document.querySelectorAll("[data-home-count-card]")];
  const homeArtistCount = document.querySelector("[data-home-artist-count]");
  const homeReleaseCount = document.querySelector("[data-home-release-count]");
  const homeRegionCounts = document.querySelector("[data-home-region-counts]");
  const homeRegionCountValues = [...document.querySelectorAll("[data-home-region-count]")];
  const homeRegionLabels = [...document.querySelectorAll("[data-home-region-label]")];
  const homeCatalogEndpoint = homeLatestLive?.getAttribute("data-home-catalog-endpoint") || "/api/catalog?view=home&label=mbp";
  const homeFallbackMark = homeLatestLive?.getAttribute("data-home-fallback-mark") || "MBP";
  const homeReleaseCopy = homeLatestLive?.getAttribute("data-home-release-copy") || "Choose your preferred streaming service or open the full release page.";

  const escapeLatestHtml = (value) =>
    String(value ?? "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#39;");

  function renderHomeRelease(release, index = 0) {
    const releasePath = `/release/${encodeURIComponent(String(release.slug || release.catalog_number || "").toLowerCase())}`;
    const links = Array.isArray(release.platform_links) ? release.platform_links : [];
    const playableLinks = links.filter((link) => !/email|subscribe/i.test(`${link.platform || ""} ${link.label || ""}`));
    const isPresave = release.status === "presave" && playableLinks.length === 0;
    const smartLink = release.presave_url || release.ffm_url;
    const loading = index === 0 ? "eager" : "lazy";
    const regionColor = release.mbp_region_color || "#bd00ff";
    const regionLabel = release.mbp_region_label || "MBP World";

    return `
      <article class="group clip-diagonal relative overflow-hidden border bg-graphite/90" style="border-color:${escapeLatestHtml(regionColor)}55; box-shadow:0 0 24px ${escapeLatestHtml(regionColor)}1a;">
        <div class="relative grid min-h-full grid-rows-[auto_1fr]">
          <a class="aspect-square overflow-hidden border-b border-white/10 bg-black/70" href="${escapeLatestHtml(releasePath)}">
            ${
              release.artwork_url
                ? `<img src="${escapeLatestHtml(release.artwork_url)}" alt="${escapeLatestHtml(release.title)} artwork" class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.03]" loading="${loading}" decoding="async" sizes="(min-width: 1024px) 25vw, (min-width: 640px) 50vw, 100vw" />`
                : `<div class="grid h-full w-full place-items-center bg-black font-display text-5xl font-black text-white">${escapeLatestHtml(homeFallbackMark)}</div>`
            }
          </a>
          <div class="p-5">
            <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-neon-cyan">${escapeLatestHtml(release.catalog_number)} | ${isPresave ? "Pre-save" : "Published"}</p>
            <p class="mt-2 inline-flex rounded border px-2 py-1 text-[0.68rem] font-black uppercase tracking-[0.14em]" style="border-color:${escapeLatestHtml(regionColor)}66; color:${escapeLatestHtml(regionColor)}">${escapeLatestHtml(regionLabel)}</p>
            <h3 class="mt-3 font-display text-2xl font-black uppercase leading-none text-white"><a class="hover:text-neon-cyan" href="${escapeLatestHtml(releasePath)}">${escapeLatestHtml(release.title)}</a></h3>
            <p class="mt-2 text-sm font-semibold text-haze">${escapeLatestHtml(release.artist_display)}</p>
            <p class="mt-4 text-sm leading-6 text-steel">${isPresave ? "Pre-save is open. Streaming platform links update automatically when FFM publishes destinations." : escapeLatestHtml(homeReleaseCopy)}</p>
            <div class="mt-5 flex flex-wrap gap-2 text-xs font-bold uppercase tracking-[0.12em] text-white/80">
              ${smartLink ? `<a class="rounded bg-white/10 px-2.5 py-1.5 hover:bg-neon-cyan hover:text-black" href="${escapeLatestHtml(smartLink)}" target="_blank" rel="noreferrer">${isPresave ? "Pre-save" : "Smart link"}</a>` : ""}
              <a class="rounded bg-white/10 px-2.5 py-1.5 hover:bg-neon-cyan hover:text-black" href="${escapeLatestHtml(releasePath)}">Details</a>
            </div>
          </div>
        </div>
      </article>
    `;
  }

  function updateHomeCounts(counts) {
    if (!counts) return;
    if (homeArtistCount) homeArtistCount.textContent = String(counts.artists ?? 0);
    if (homeReleaseCount) homeReleaseCount.textContent = String(counts.releases ?? 0);
    homeCountCards.forEach((card) => card.classList.remove("hidden"));
    if (Array.isArray(counts.regions)) {
      const regionMap = new Map(counts.regions.map((region) => [region.key, region.releases]));
      homeRegionCountValues.forEach((element) => {
        const key = element.getAttribute("data-home-region-count");
        element.textContent = String(regionMap.get(key) ?? 0);
      });
      homeRegionLabels.forEach((element) => {
        const key = element.getAttribute("data-home-region-label");
        const count = Number(regionMap.get(key) ?? 0);
        const baseLabel = element.getAttribute("data-home-region-name") || element.textContent.replace(/\s+releases?$/gi, "").trim();
        element.textContent = `${baseLabel} ${count === 1 ? "release" : "releases"}`;
      });
      homeRegionCounts?.classList.remove("hidden");
    }
  }

  async function loadHomeLatestReleases() {
    if (!homeLatestLive || !homePublishedGrid) return;

    try {
      const response = await fetch(homeCatalogEndpoint, { cache: "no-store" });
      const data = await response.json();
      const published = Array.isArray(data.releases) ? data.releases.slice(0, 4) : [];
      const presaves = Array.isArray(data.presaves) ? data.presaves.slice(0, 4) : [];
      if (!data.ok || (published.length === 0 && presaves.length === 0)) {
        homeStaticReleases?.classList.remove("hidden");
        updateHomeCounts(data.counts);
        return;
      }

      homeLatestLive.classList.remove("hidden");
      homeStaticReleases?.classList.add("hidden");
      updateHomeCounts(data.counts);
      homePublishedGrid.innerHTML = published.map(renderHomeRelease).join("");

      if (presaves.length > 0 && homePresaveSection && homePresaveGrid) {
        homePresaveSection.classList.remove("hidden");
        homePresaveGrid.innerHTML = presaves.map(renderHomeRelease).join("");
      }
    } catch {
      homeStaticReleases?.classList.remove("hidden");
    }
  }

  loadHomeLatestReleases();
</script>
