---
interface Props {
  label?: string;
  labelName?: string;
  eyebrow?: string;
  title?: string;
  searchPlaceholder?: string;
  allRegionLabel?: string;
  showRegionFilters?: boolean;
}

const {
  label = "mbp",
  labelName = "The MasterBeat Project",
  eyebrow = "Label roster",
  title = "MBP artists",
  searchPlaceholder = "Search Terror Basslines, Romee Storm or hardstyle",
  allRegionLabel = "All MBP",
  showRegionFilters = true
} = Astro.props;
const catalogEndpoint = `/api/catalog?label=${encodeURIComponent(label)}`;
---

<section class="py-20" data-live-artists-section data-artist-catalog-endpoint={catalogEndpoint} data-label-name={labelName} data-show-region-filters={String(showRegionFilters)}>
  <div class="section-shell">
    <p class="eyebrow">{eyebrow}</p>
    <h2 class="mt-3 font-display text-3xl font-black uppercase leading-none text-white sm:text-5xl">{title}</h2>
    <div class="mt-8 rounded-lg border border-white/10 bg-carbon/75 p-4">
      <label>
        <span class="field-label">Search artist roster</span>
        <input class="field-control" type="search" placeholder={searchPlaceholder} data-artist-search />
      </label>
      {
        showRegionFilters && (
          <div class="mt-4 flex flex-wrap gap-2" aria-label="MBP region artist filter">
            <button class="rounded-md bg-white px-3 py-2 text-xs font-black uppercase tracking-[0.12em] text-black" data-artist-region="all" type="button">{allRegionLabel}</button>
            <button class="rounded-md border border-white/10 px-3 py-2 text-xs font-black uppercase tracking-[0.12em] text-haze hover:text-white" data-artist-region="europe" type="button">Europe</button>
            <button class="rounded-md border border-white/10 px-3 py-2 text-xs font-black uppercase tracking-[0.12em] text-haze hover:text-white" data-artist-region="america" type="button">America</button>
            <button class="rounded-md border border-white/10 px-3 py-2 text-xs font-black uppercase tracking-[0.12em] text-haze hover:text-white" data-artist-region="asia" type="button">Asia</button>
            <button class="rounded-md border border-white/10 px-3 py-2 text-xs font-black uppercase tracking-[0.12em] text-haze hover:text-white" data-artist-region="world" type="button">World</button>
            <button class="rounded-md border border-white/10 px-3 py-2 text-xs font-black uppercase tracking-[0.12em] text-haze hover:text-white" data-artist-region="australia" type="button">Australia</button>
          </div>
        )
      }
    </div>
    <div class="mt-6 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
      <p class="text-sm text-steel" data-artist-count>Loading artists...</p>
      <button class="hidden rounded-md border border-white/10 px-4 py-2 text-xs font-bold uppercase tracking-[0.12em] text-haze hover:border-neon-cyan hover:text-white" data-artist-clear type="button">Clear search</button>
    </div>
    <div class="mt-10 grid gap-5 md:grid-cols-2" data-live-artists></div>
    <div class="mt-8" data-artist-pager></div>
  </div>
</section>

<script>
  // @ts-nocheck
  const liveArtistsSection = document.querySelector("[data-live-artists-section]");
  const liveArtists = document.querySelector("[data-live-artists]");
  const staticArtists = document.querySelector("[data-static-artists]");
  const artistSearch = document.querySelector("[data-artist-search]");
  const artistClear = document.querySelector("[data-artist-clear]");
  const artistCount = document.querySelector("[data-artist-count]");
  const artistPager = document.querySelector("[data-artist-pager]");
  const artistRegionButtons = [...document.querySelectorAll("[data-artist-region]")];
  const artistCatalogEndpoint = liveArtistsSection?.getAttribute("data-artist-catalog-endpoint") || "/api/catalog?label=mbp";
  const artistLabelName = liveArtistsSection?.getAttribute("data-label-name") || "The MasterBeat Project";
  const showArtistRegionFilters = liveArtistsSection?.getAttribute("data-show-region-filters") !== "false";
  let allArtists = [];
  let visibleArtists = [];
  let artistPage = 1;
  let artistRegionFilter = "all";
  const artistPageSize = 12;

  const escapeArtistHtml = (value) =>
    String(value ?? "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#39;");

  function searchableArtistText(artist) {
    const labels = Array.isArray(artist.labels) ? artist.labels.map((label) => `${label.name || ""} ${label.shortName || ""}`).join(" ") : "";
    return [artist.name, artist.country, artist.profile, artist.mbp_region, artist.mbp_region_label, artist.release_label_name, artist.release_label_short_name, labels]
      .filter(Boolean)
      .join(" ")
      .toLowerCase();
  }

  function updateArtistRegionButtons() {
    artistRegionButtons.forEach((button) => {
      const active = button.getAttribute("data-artist-region") === artistRegionFilter;
      button.className = active
        ? "rounded-md bg-white px-3 py-2 text-xs font-black uppercase tracking-[0.12em] text-black"
        : "rounded-md border border-white/10 px-3 py-2 text-xs font-black uppercase tracking-[0.12em] text-haze hover:text-white";
    });
  }

  function filterArtists() {
    const query = String(artistSearch?.value || "").trim().toLowerCase();
    visibleArtists = allArtists.filter((artist) => {
      const regionMatch = !showArtistRegionFilters || artistRegionFilter === "all" || artist.mbp_region === artistRegionFilter;
      const searchMatch = !query || searchableArtistText(artist).includes(query);
      return regionMatch && searchMatch;
    });
    artistClear?.classList.toggle("hidden", !query);
  }

  function renderArtist(artist) {
    const artistPath = `/artist/${encodeURIComponent(String(artist.slug || artist.name || "").toLowerCase())}`;
    const regionColor = (!showArtistRegionFilters && artist.release_label_color) || artist.mbp_region_color || "#bd00ff";
    const regionLabel = showArtistRegionFilters ? artist.mbp_region_label || "MBP World" : artist.release_label_name || artistLabelName;
    return `
      <article class="rounded-lg border bg-carbon/80 p-5" style="border-color:${escapeArtistHtml(regionColor)}66; box-shadow:0 0 22px ${escapeArtistHtml(regionColor)}14;">
        <div class="flex items-center gap-4">
          <a href="${escapeArtistHtml(artistPath)}" aria-label="${escapeArtistHtml(artist.name)} artist profile">
            ${artist.image_url ? `<img class="h-20 w-20 rounded-md border border-white/10 object-cover" src="${escapeArtistHtml(artist.image_url)}" alt="" loading="lazy" decoding="async" />` : `<div class="grid h-20 w-20 place-items-center rounded-md border border-white/10 bg-black font-display text-3xl font-black text-white">${escapeArtistHtml(String(artist.name || "?").slice(0, 1))}</div>`}
          </a>
          <div>
            <p class="text-xs font-bold uppercase tracking-[0.18em] text-neon-cyan">Artist</p>
            <h3 class="mt-2 font-display text-3xl font-black uppercase leading-none text-white"><a class="hover:text-neon-cyan" href="${escapeArtistHtml(artistPath)}">${escapeArtistHtml(artist.name)}</a></h3>
            <p class="mt-1 text-sm text-steel">${escapeArtistHtml(artist.country || "The MasterBeat Project")}</p>
            <p class="mt-2 inline-flex rounded border px-2 py-1 text-[0.68rem] font-black uppercase tracking-[0.14em]" style="border-color:${escapeArtistHtml(regionColor)}66; color:${escapeArtistHtml(regionColor)}">${escapeArtistHtml(regionLabel)}</p>
          </div>
        </div>
        <p class="mt-5 text-sm leading-6 text-haze">${escapeArtistHtml(artist.profile || "Artist profile coming soon.")}</p>
        <div class="mt-5 flex flex-wrap gap-2">
          <a class="rounded-md border border-white/10 px-3 py-2 text-xs font-bold uppercase tracking-[0.1em] text-haze hover:border-neon-cyan hover:text-white" href="${escapeArtistHtml(artistPath)}">Profile</a>
          ${(artist.links || []).map((link) => `<a class="rounded-md border border-white/10 px-3 py-2 text-xs font-bold uppercase tracking-[0.1em] text-haze hover:border-neon-cyan hover:text-white" href="${escapeArtistHtml(link.url)}" target="_blank" rel="noreferrer">${escapeArtistHtml(link.label)}</a>`).join("")}
        </div>
      </article>
    `;
  }

  function renderArtistPager() {
    if (!artistPager) return;
    const totalPages = Math.max(1, Math.ceil(visibleArtists.length / artistPageSize));
    if (totalPages <= 1) {
      artistPager.innerHTML = "";
      return;
    }
    const start = (artistPage - 1) * artistPageSize + 1;
    const end = Math.min(visibleArtists.length, artistPage * artistPageSize);
    artistPager.innerHTML = `
      <div class="flex flex-col gap-3 rounded-md border border-white/10 bg-black/30 p-3 sm:flex-row sm:items-center sm:justify-between">
        <p class="text-xs uppercase tracking-[0.14em] text-steel">Showing ${start}-${end} of ${visibleArtists.length}</p>
        <div class="flex gap-2">
          <button class="rounded border border-white/10 px-3 py-2 text-xs font-bold uppercase text-haze disabled:opacity-40" data-artist-page="-1" ${artistPage <= 1 ? "disabled" : ""} type="button">Previous</button>
          <span class="rounded border border-white/10 px-3 py-2 text-xs font-bold uppercase text-white">${artistPage} / ${totalPages}</span>
          <button class="rounded border border-white/10 px-3 py-2 text-xs font-bold uppercase text-haze disabled:opacity-40" data-artist-page="1" ${artistPage >= totalPages ? "disabled" : ""} type="button">Next</button>
        </div>
      </div>
    `;
  }

  function renderArtists() {
    if (!liveArtists) return;
    filterArtists();
    const totalPages = Math.max(1, Math.ceil(visibleArtists.length / artistPageSize));
    artistPage = Math.min(Math.max(1, artistPage), totalPages);
    const pageItems = visibleArtists.slice((artistPage - 1) * artistPageSize, artistPage * artistPageSize);
    if (artistCount) artistCount.textContent = `${visibleArtists.length} artist${visibleArtists.length === 1 ? "" : "s"} found`;
    liveArtists.innerHTML = pageItems.length
      ? pageItems.map(renderArtist).join("")
      : `<div class="rounded-lg border border-white/10 bg-carbon/80 p-6 text-sm text-steel md:col-span-2">No artists match this search.</div>`;
    renderArtistPager();
  }

  async function loadLiveArtists() {
    if (!liveArtistsSection || !liveArtists) return;
    try {
      const response = await fetch(artistCatalogEndpoint, { cache: "no-store" });
      const data = await response.json();
      if (!data.ok || !Array.isArray(data.artists) || data.artists.length === 0) {
        staticArtists?.classList.remove("hidden");
        if (artistCount) artistCount.textContent = "Static roster loaded.";
        return;
      }

      staticArtists?.classList.add("hidden");
      allArtists = data.artists;
      renderArtists();
    } catch {
      staticArtists?.classList.remove("hidden");
      liveArtists.innerHTML = `<div class="rounded-lg border border-white/10 bg-carbon/80 p-6 text-sm text-steel md:col-span-2">Live roster is temporarily unavailable.</div>`;
    }
  }

  artistSearch?.addEventListener("input", () => {
    artistPage = 1;
    renderArtists();
  });

  artistClear?.addEventListener("click", () => {
    if (artistSearch) artistSearch.value = "";
    artistPage = 1;
    renderArtists();
  });

  artistRegionButtons.forEach((button) => {
    button.addEventListener("click", () => {
      artistRegionFilter = button.getAttribute("data-artist-region") || "all";
      artistPage = 1;
      updateArtistRegionButtons();
      renderArtists();
    });
  });

  document.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;
    const button = target.closest("[data-artist-page]");
    if (!button) return;
    artistPage += Number(button.getAttribute("data-artist-page"));
    renderArtists();
    liveArtistsSection?.scrollIntoView({ behavior: "smooth", block: "start" });
  });

  updateArtistRegionButtons();
  loadLiveArtists();
</script>
