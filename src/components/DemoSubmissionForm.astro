---
const genres = ["Hardstyle", "Rawstyle", "Euphoric hardstyle", "Hardcore", "Uptempo", "Hard dance", "Electronic", "Other"];
const socialPlatforms = [
  { key: "spotify", label: "Spotify", placeholder: "https://open.spotify.com/artist/..." },
  { key: "instagram", label: "Instagram", placeholder: "https://instagram.com/artist" },
  { key: "youtube", label: "YouTube", placeholder: "https://youtube.com/@artist" },
  { key: "facebook", label: "Facebook", placeholder: "https://facebook.com/artist" },
  { key: "soundcloud", label: "SoundCloud", placeholder: "https://soundcloud.com/artist" },
  { key: "tiktok", label: "TikTok", placeholder: "https://tiktok.com/@artist" },
  { key: "x", label: "X / Twitter", placeholder: "https://x.com/artist" },
  { key: "threads", label: "Threads", placeholder: "https://threads.net/@artist" },
  { key: "apple", label: "Apple Music", placeholder: "https://music.apple.com/artist/..." },
  { key: "beatport", label: "Beatport", placeholder: "https://beatport.com/artist/..." },
  { key: "bandcamp", label: "Bandcamp", placeholder: "https://artist.bandcamp.com" },
  { key: "audiomack", label: "Audiomack", placeholder: "https://audiomack.com/artist" },
  { key: "linktree", label: "Linktree", placeholder: "https://linktr.ee/artist" },
  { key: "website", label: "Website", placeholder: "https://artist.com" }
];
---

<form class="surface rounded-lg p-5 sm:p-7" data-demo-form data-endpoint="/api/demo-submission" novalidate>
  <div class="grid gap-5 md:grid-cols-2">
    <label>
      <span class="field-label">Artist name</span>
      <input class="field-control" name="artistName" type="text" autocomplete="name" required minlength="2" placeholder="Your artist name" />
    </label>

    <label>
      <span class="field-label">Email</span>
      <input class="field-control" name="email" type="email" autocomplete="email" required placeholder="artist@example.com" />
    </label>

    <label>
      <span class="field-label">Country</span>
      <input class="field-control" name="country" type="text" autocomplete="country-name" required placeholder="Country" />
    </label>

    <input name="links" type="hidden" data-demo-social-output />

    <fieldset class="md:col-span-2">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
        <legend class="field-label">Artist / social links</legend>
        <span class="text-xs leading-5 text-steel">Add at least one official artist profile.</span>
      </div>
      <div class="mt-3 grid gap-3 md:grid-cols-2">
        {
          socialPlatforms.map((platform) => (
            <label>
              <span class="field-label">{platform.label}</span>
              <input
                class="field-control"
                name={`social_${platform.key}`}
                type="url"
                inputmode="url"
                placeholder={platform.placeholder}
                data-demo-social-link
                data-social-label={platform.label}
              />
            </label>
          ))
        }
      </div>
    </fieldset>

    <label>
      <span class="field-label">Track title</span>
      <input class="field-control" name="trackTitle" type="text" required minlength="2" placeholder="Track title" />
    </label>

    <label>
      <span class="field-label">Genre</span>
      <select class="field-control" name="genre" required>
        <option value="">Select genre</option>
        {genres.map((genre) => <option value={genre}>{genre}</option>)}
      </select>
    </label>

    <label class="md:col-span-2">
      <span class="field-label">Private streaming link</span>
      <input class="field-control" name="streamingLink" type="url" inputmode="url" required placeholder="Private SoundCloud, Dropbox, Google Drive or similar" />
    </label>

    <label class="md:col-span-2">
      <span class="field-label">Optional file upload</span>
      <input class="field-control" name="fileUpload" type="file" accept="audio/*,.wav,.mp3,.aiff,.aif,.flac,image/*" />
      <span class="mt-2 block text-xs leading-5 text-steel">Optional audio or artwork files are stored privately in Cloudflare R2 for admin review.</span>
    </label>

    <label class="md:col-span-2">
      <span class="field-label">Short message</span>
      <textarea class="field-control min-h-36 resize-y" name="message" required minlength="20" maxlength="1200" placeholder="Tell us what makes the track fit The MasterBeat Project."></textarea>
    </label>
  </div>

  <label class="mt-6 flex gap-3 text-sm leading-6 text-haze">
    <input class="mt-1 h-4 w-4 rounded border-white/20 bg-black text-neon-violet" name="agreement" type="checkbox" required />
    <span>I confirm that I own or control the submitted music and agree that The MasterBeat Project may review the private link for label consideration.</span>
  </label>

  <div class="mt-7 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <button class="inline-flex min-h-12 items-center justify-center rounded-md bg-white px-6 py-3 text-sm font-black uppercase tracking-[0.14em] text-black transition hover:bg-neon-cyan" type="submit">
      Submit Demo
    </button>
    <p class="text-sm text-steel" data-demo-status aria-live="polite">Private links are required. File upload is optional.</p>
  </div>
</form>

<script>
  // @ts-nocheck
  const form = document.querySelector("[data-demo-form]");
  const status = document.querySelector("[data-demo-status]");
  const socialOutput = document.querySelector("[data-demo-social-output]");
  const socialInputs = [...document.querySelectorAll("[data-demo-social-link]")];

  if (form instanceof HTMLFormElement && status instanceof HTMLElement) {
    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      if (!form.checkValidity()) {
        status.textContent = "Please complete the required fields before submitting.";
        form.reportValidity();
        return;
      }

      const formData = new FormData(form);
      const agreement = formData.get("agreement");
      const socialLines = socialInputs
        .map((input) => {
          const value = String(input.value || "").trim();
          const label = input.getAttribute("data-social-label") || input.name;
          return value ? `${label}: ${value}` : "";
        })
        .filter(Boolean);

      if (!agreement) {
        status.textContent = "Agreement is required before a demo can be reviewed.";
        return;
      }

      if (socialLines.length === 0) {
        status.textContent = "Please add at least one official artist or social link.";
        socialInputs[0]?.focus();
        return;
      }

      formData.set("agreement", "true");
      formData.set("links", socialLines.join("\n"));
      if (socialOutput instanceof HTMLInputElement) socialOutput.value = socialLines.join("\n");
      status.textContent = "Submitting demo...";

      try {
        const response = await fetch(form.dataset.endpoint || "/api/demo-submission", {
          method: "POST",
          body: formData
        });
        const data = await response.json();
        if (!response.ok || data.ok === false) {
          throw new Error(data.error || "Demo submission failed.");
        }
        status.textContent = "Demo received. Thank you for sending music to The MasterBeat Project.";
        form.reset();
      } catch (error) {
        status.textContent = error instanceof Error ? error.message : "Demo submission failed.";
      }
    });
  }
</script>
