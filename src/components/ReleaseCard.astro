---
import type { Release } from "../data/site";

interface Props {
  release: Release;
}

const { release } = Astro.props;

const accentClasses = {
  violet: "from-neon-violet/35 via-neon-blue/18 to-transparent",
  blue: "from-neon-blue/35 via-neon-cyan/16 to-transparent",
  red: "from-neon-red/35 via-neon-violet/12 to-transparent",
  amber: "from-neon-amber/35 via-neon-red/10 to-transparent",
  green: "from-neon-green/30 via-neon-cyan/10 to-transparent"
};
---

<article class="group clip-diagonal relative overflow-hidden border border-white/10 bg-graphite/90">
  <div class:list={["absolute inset-0 bg-gradient-to-br opacity-70 transition duration-300 group-hover:opacity-100", accentClasses[release.accent]]}></div>
  <div class="relative grid min-h-full grid-rows-[auto_1fr]">
    <div class="aspect-square overflow-hidden border-b border-white/10 bg-black/55">
      <img src={release.artwork} alt={`${release.title} artwork`} class="h-full w-full object-contain transition duration-500 group-hover:scale-[1.03]" loading="lazy" />
    </div>
    <div class="p-5">
      <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-neon-cyan">{release.catalog}</p>
      <h3 class="mt-3 font-display text-2xl font-black uppercase leading-none text-white">{release.title}</h3>
      <p class="mt-2 text-sm font-semibold text-haze">{release.sound}</p>
      <p class="mt-4 text-sm leading-6 text-steel">{release.description}</p>
      <div class="mt-5 flex flex-wrap gap-2 text-xs font-bold uppercase tracking-[0.12em] text-white/80">
        <span class="rounded bg-white/10 px-2.5 py-1.5">{release.format}</span>
        <span class="rounded bg-white/10 px-2.5 py-1.5">{release.artist}</span>
      </div>
    </div>
  </div>
</article>
