---
interface Props {
  href: string;
  variant?: "primary" | "secondary" | "ghost";
  class?: string;
}

const { href, variant = "primary", class: className = "" } = Astro.props;

const variants = {
  primary: "bg-white text-black hover:bg-neon-cyan",
  secondary: "border border-white/15 bg-white/5 text-white hover:border-neon-cyan/60 hover:bg-neon-cyan/10",
  ghost: "text-haze hover:bg-white/10 hover:text-white"
};
---

<a
  href={href}
  class:list={[
    "inline-flex min-h-11 items-center justify-center rounded-md px-5 py-3 text-sm font-black uppercase tracking-[0.14em] transition duration-200",
    variants[variant],
    className
  ]}
>
  <slot />
</a>
