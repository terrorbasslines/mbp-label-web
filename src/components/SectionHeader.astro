---
interface Props {
  eyebrow: string;
  title: string;
  copy?: string;
  align?: "left" | "center";
}

const { eyebrow, title, copy, align = "left" } = Astro.props;
---

<div class:list={["max-w-3xl", align === "center" && "mx-auto text-center"]}>
  <p class="eyebrow">{eyebrow}</p>
  <h2 class="mt-3 font-display text-3xl font-black uppercase leading-none text-white sm:text-5xl">{title}</h2>
  {copy && <p class="mt-4 text-pretty text-base leading-7 text-steel sm:text-lg">{copy}</p>}
</div>
