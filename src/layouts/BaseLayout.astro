---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import { siteConfig } from "../data/site";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = siteConfig.name,
  description = siteConfig.seoDescription,
  image = siteConfig.defaultImage,
  type = "website",
  noindex = false,
  jsonLd = []
} = Astro.props;

const pageTitle = title === siteConfig.name ? title : `${title} | ${siteConfig.name}`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? "https://themasterbeatproject.com").toString();
const siteUrl = Astro.site ?? "https://themasterbeatproject.com";
const ogImageUrl = new URL(image, siteUrl).toString();
const logoUrl = new URL(siteConfig.logo, siteUrl).toString();
const robots = noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large";
const catalogPreloadHref = Astro.url.pathname === "/" ? "/api/catalog?view=home" : ["/releases", "/artists"].includes(Astro.url.pathname.replace(/\/$/, "")) ? "/api/catalog" : null;
const sameAs = siteConfig.socials.filter((social) => social.href.startsWith("http")).map((social) => social.href);
const pageJsonLd = Array.isArray(jsonLd) ? jsonLd : [jsonLd];
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": `${siteConfig.url}/#organization`,
    name: siteConfig.name,
    url: siteConfig.url,
    logo: logoUrl,
    image: ogImageUrl,
    description: siteConfig.seoDescription,
    sameAs
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": `${siteConfig.url}/#website`,
    name: siteConfig.name,
    url: siteConfig.url,
    publisher: { "@id": `${siteConfig.url}/#organization` },
    inLanguage: "en"
  },
  ...pageJsonLd
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="theme-color" content="#050508" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" href="/assets/brand/logo-clear.png" />
    <link rel="preconnect" href="https://cloudinary-cdn.ffm.to" crossorigin />
    <link rel="preconnect" href="https://imagestore.ffm.to" crossorigin />
    {catalogPreloadHref && <link rel="preload" as="fetch" href={catalogPreloadHref} crossorigin="anonymous" />}
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={`${siteConfig.name} brand artwork`} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <title>{pageTitle}</title>
    {structuredData.map((item) => <script is:inline type="application/ld+json" set:html={JSON.stringify(item).replace(/</g, "\\u003c")}></script>)}
  </head>
  <body>
    <a class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-neon-cyan focus:px-4 focus:py-2 focus:text-sm focus:font-bold focus:text-black" href="#main">
      Skip to content
    </a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
