---
import BaseLayout from "../layouts/BaseLayout.astro";
import ArtistCard from "../components/ArtistCard.astro";
import SectionHeader from "../components/SectionHeader.astro";
import ButtonLink from "../components/ButtonLink.astro";
import LiveArtists from "../components/LiveArtists.astro";
import { artists } from "../data/site";
---

<BaseLayout title="Artists" description="Artist profiles and roster presentation for The MasterBeat Project.">
  <section class="border-b border-white/10 bg-black/45 py-20">
    <div class="section-shell">
      <p class="eyebrow">Roster</p>
      <h1 class="page-title mt-4">Artists</h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-haze">
        A public artist profile surface for featured MBP collaborators, future biographies, release histories and press-ready links.
      </p>
    </div>
  </section>

  <LiveArtists />

  <section class="py-20" data-static-artists>
    <div class="section-shell">
      <div class="grid gap-5 md:grid-cols-2">
        {artists.map((artist) => <ArtistCard artist={artist} />)}
      </div>
    </div>
  </section>

  <section class="border-y border-white/10 bg-rail-grid bg-[length:100%_100%,44px_44px] py-20">
    <div class="section-shell grid gap-10 lg:grid-cols-[0.8fr_1.2fr]">
      <SectionHeader eyebrow="Profile model" title="Built for growth" copy="The component structure can expand into individual artist routes with biographies, press shots, release lists and social links." />
      <div class="grid gap-4 sm:grid-cols-3">
        {["Biography", "Discography", "Press assets"].map((item) => (
          <div class="rounded-lg border border-white/10 bg-black/50 p-5">
            <p class="font-display text-2xl font-black uppercase text-white">{item}</p>
            <p class="mt-3 text-sm leading-6 text-steel">Prepared for the next backend or content layer.</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="section-shell flex flex-col gap-5 rounded-lg border border-neon-violet/30 bg-carbon/80 p-6 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <p class="eyebrow">Join the sound</p>
        <h2 class="mt-2 font-display text-3xl font-black uppercase text-white">Send your strongest track</h2>
      </div>
      <ButtonLink href="/demo-submission">Submit Demo</ButtonLink>
    </div>
  </section>
</BaseLayout>
