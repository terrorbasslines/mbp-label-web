---
import BaseLayout from "../layouts/BaseLayout.astro";
import ReleaseCard from "../components/ReleaseCard.astro";
import SectionHeader from "../components/SectionHeader.astro";
import ButtonLink from "../components/ButtonLink.astro";
import LiveCatalog from "../components/LiveCatalog.astro";
import { releases, siteConfig } from "../data/site";

const releasesJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "The MasterBeat Project releases",
  url: `${siteConfig.url}/releases`,
  description:
    "Official The MasterBeat Project catalogue with hardstyle, hard dance and electronic releases, MBP catalogue numbers and streaming links.",
  isPartOf: { "@id": `${siteConfig.url}/#website` }
};
---

<BaseLayout
  title="Hardstyle and Electronic Music Releases"
  description="Explore official The MasterBeat Project releases, MBP catalogue numbers, artist credits and streaming links for hardstyle, hard dance and electronic music."
  jsonLd={releasesJsonLd}
>
  <section class="border-b border-white/10 bg-black/45 py-20">
    <div class="section-shell">
        <p class="eyebrow">Official catalogue</p>
        <h1 class="page-title mt-4">Hardstyle and electronic releases</h1>
        <p class="mt-6 max-w-3xl text-lg leading-8 text-haze">
        Explore official MBP catalogue releases with artist credits, release artwork and links to streaming platforms including Spotify, Apple Music, YouTube, SoundCloud and more when available.
      </p>
    </div>
  </section>

  <LiveCatalog />

  <section class="py-20" data-static-releases>
    <div class="section-shell">
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {releases.map((release) => <ReleaseCard release={release} />)}
      </div>
    </div>
  </section>

  <section class="border-y border-white/10 bg-black/40 py-20">
    <div class="section-shell grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
      <SectionHeader eyebrow="Release system" title="Ready for catalogue data" copy="The current content is local and static. The structure is ready to move releases into D1 or a headless CMS when the backend is introduced." />
      <div class="grid gap-4 sm:grid-cols-2">
        {["Artwork", "Metadata", "Artists", "Streaming links"].map((item) => (
          <div class="rounded-lg border border-white/10 bg-white/[0.035] p-5">
            <p class="font-display text-2xl font-black uppercase text-white">{item}</p>
            <p class="mt-2 text-sm leading-6 text-steel">Reserved for production release information and public distribution references.</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="section-shell flex flex-col gap-5 rounded-lg border border-white/10 bg-carbon/70 p-6 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <p class="eyebrow">New music</p>
        <h2 class="mt-2 font-display text-3xl font-black uppercase text-white">Send a serious demo</h2>
      </div>
      <ButtonLink href="/demo-submission">Submit Demo</ButtonLink>
    </div>
  </section>
</BaseLayout>
