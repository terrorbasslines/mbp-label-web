---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/SectionHeader.astro";
import ButtonLink from "../components/ButtonLink.astro";
---

<BaseLayout title="About" description="About The MasterBeat Project electronic music label.">
  <section class="relative overflow-hidden border-b border-white/10 bg-black/45 py-20">
    <img src="/assets/brand/season4-banner.png" alt="" class="absolute inset-0 h-full w-full object-cover opacity-20" />
    <div class="absolute inset-0 bg-gradient-to-r from-black via-black/80 to-black/35"></div>
    <div class="section-shell relative">
      <p class="eyebrow">About</p>
      <h1 class="page-title mt-4">The label identity</h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-haze">
        The MasterBeat Project is shaped around harder electronic music, strong visual direction and release presentation that feels serious enough for artists, promoters and listeners.
      </p>
    </div>
  </section>

  <section class="py-20">
    <div class="section-shell grid gap-10 lg:grid-cols-[0.8fr_1.2fr]">
      <SectionHeader eyebrow="Mission" title="A sharper home for hard electronic music" />
      <div class="space-y-5 text-pretty text-lg leading-8 text-haze">
        <p>
          The label website is designed as a public foundation for releases, artist pages, demo review and future administrative tooling.
        </p>
        <p>
          The visual language keeps the MBP mark at the center: dark stage environments, high-contrast typography and controlled electric accents that support the music instead of distracting from it.
        </p>
      </div>
    </div>
  </section>

  <section class="border-y border-white/10 bg-black/40 py-20">
    <div class="section-shell grid gap-5 md:grid-cols-3">
      {[
        ["Artist-first", "Clear paths for demo review, artist profiles and release presentation."],
        ["Catalogue-ready", "Reusable data structures for releases, metadata, artwork and streaming links."],
        ["Cloudflare-ready", "Prepared for Pages, Functions, D1 metadata storage and R2 file handling."]
      ].map(([title, copy]) => (
        <div class="rounded-lg border border-white/10 bg-carbon/70 p-6">
          <h2 class="font-display text-3xl font-black uppercase text-white">{title}</h2>
          <p class="mt-4 text-sm leading-6 text-steel">{copy}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="py-20">
    <div class="section-shell flex flex-col gap-5 sm:flex-row sm:items-center sm:justify-between">
      <SectionHeader eyebrow="Next step" title="Send music or contact the label" />
      <div class="flex flex-col gap-3 sm:flex-row">
        <ButtonLink href="/demo-submission">Submit Demo</ButtonLink>
        <ButtonLink href="/contact" variant="secondary">Contact</ButtonLink>
      </div>
    </div>
  </section>
</BaseLayout>
