---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../data/site";
---

<BaseLayout
  title="Privacy Policy"
  description="Privacy policy for The MasterBeat Project website, demo submissions and label communication."
>
  <section class="border-b border-white/10 bg-black/45 py-20">
    <div class="section-shell">
      <p class="eyebrow">Privacy</p>
      <h1 class="page-title mt-4">Privacy Policy</h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-haze">Last updated: May 26, 2026</p>
    </div>
  </section>

  <section class="py-16">
    <div class="section-shell max-w-4xl space-y-8 text-pretty text-base leading-7 text-haze">
      <div>
        <h2 class="font-display text-3xl font-black uppercase text-white">Overview</h2>
        <p class="mt-3">This website presents {siteConfig.name}, its releases, artists, demo submission information and contact options.</p>
      </div>

      <div>
        <h2 class="font-display text-3xl font-black uppercase text-white">Information collected</h2>
        <p class="mt-3">When the demo backend is connected, the site may collect artist name, email, country, artist links, track information, private streaming links, optional files and message content submitted by the artist.</p>
      </div>

      <div>
        <h2 class="font-display text-3xl font-black uppercase text-white">How information is used</h2>
        <p class="mt-3">Submission information is intended for label review, artist communication, release consideration and operational record keeping.</p>
      </div>

      <div>
        <h2 class="font-display text-3xl font-black uppercase text-white">Storage and services</h2>
        <p class="mt-3">The planned backend architecture uses Cloudflare Workers for form handling, Cloudflare D1 for metadata and Cloudflare R2 for optional audio or artwork file storage.</p>
      </div>

      <div>
        <h2 class="font-display text-3xl font-black uppercase text-white">Contact</h2>
        <p class="mt-3">Privacy questions can be sent to <a class="text-neon-cyan hover:text-white" href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>.</p>
      </div>
    </div>
  </section>
</BaseLayout>
