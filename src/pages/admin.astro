              <article class="rounded-md border border-white/10 bg-black/35 p-4">
                <div class="flex items-start justify-between gap-3">
                  <div>
                    <p class="font-bold text-white"><a class="hover:text-neon-cyan" href="${escapeHtml(artistPath)}" target="_blank" rel="noreferrer">${escapeHtml(artist.name)}</a></p>
                    <p class="mt-1 text-sm text-steel">${escapeHtml(artist.country || "No country")} ${artist.is_featured ? " | Featured" : ""}</p>
                    <div class="mt-2">${renderRegionBadge(artist.mbp_region)}</div>
                  </div>
                  <div class="flex flex-wrap gap-2">
                    <a class="text-xs font-bold uppercase text-neon-cyan hover:text-white" href="${escapeHtml(artistPath)}" target="_blank" rel="noreferrer">Profile</a>
                    <button class="text-xs font-bold uppercase text-neon-cyan hover:text-white" data-edit-artist="${escapeHtml(artist.id)}" type="button">Edit</button>
                    <button class="text-xs font-bold uppercase text-neon-cyan hover:text-white" data-delete-artist="${escapeHtml(artist.id)}" type="button">Delete</button>
                  </div>
                </div>
                <p class="mt-3 text-sm leading-6 text-haze">${escapeHtml(artist.profile || "No profile yet.")}</p>
                ${
                  artist.claimed
                    ? `<div class="mt-4 rounded-md border border-neon-cyan/25 bg-neon-cyan/5 p-3 text-xs text-haze">
                        <p class="font-bold uppercase tracking-[0.12em] text-neon-cyan">Profile claimed</p>
                        <p class="mt-2">Claimed by ${escapeHtml(artist.claimed_email || "artist account")} (${escapeHtml(artist.claimed_role || "artist")}). New claim links are disabled for this profile.</p>
                      </div>`
                    : `<form class="mt-4 grid gap-2 border-t border-white/10 pt-4 md:grid-cols-[1fr_auto_auto]" data-invite-form="${escapeHtml(artist.id)}">
                        <input class="field-control" name="email" type="email" placeholder="artist@email.com" />
                        <select class="field-control" name="role">
                          <option value="artist" ${defaultRole === "artist" ? "selected" : ""}>Artist</option>
                          <option value="admin" ${defaultRole === "admin" ? "selected" : ""}>Admin</option>
                        </select>
