  function renderStats() {
    if (!statsEl) return;
    const items = [
      { label: "Artists", value: artists.length },
      { label: "Releases", value: releases.length },
      { label: "News posts", value: newsArticles.length, href: "/news/" },
      { label: "Pending demos", value: submissionCounts.pending },
      { label: "Archive demos", value: submissionCounts.archived, href: "/admin/demo-archive/" }
    ];
    statsEl.innerHTML = items
      .map((item) => {
        const content = `<p class="font-display text-4xl font-black uppercase text-white">${item.value}</p><p class="mt-2 text-sm uppercase tracking-[0.14em] text-steel">${item.label}</p>`;
        return item.href
          ? `<a class="block rounded-lg border border-white/10 bg-black/40 p-5 transition hover:border-neon-cyan hover:bg-neon-cyan/5" href="${item.href}">${content}</a>`
          : `<div class="rounded-lg border border-white/10 bg-black/40 p-5">${content}</div>`;
      })
      .join("");
  }

  function renderArtists() {
