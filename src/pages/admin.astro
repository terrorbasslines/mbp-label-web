  function platformLinksToText(links) {
    return Array.isArray(links)
      ? links.map((link) => `${link.platform || ""}|${link.label || link.platform || ""}|${link.url || ""}`).join("\n")
      : "";
  }

  function resetReleaseEditor() {
    if (!(releaseForm instanceof HTMLFormElement)) return;
    releaseForm.reset();
    releaseForm.removeAttribute("data-editing-release");
    if (releaseFormTitle) releaseFormTitle.textContent = "Add catalogue item";
    if (releaseSubmit) releaseSubmit.textContent = "Save release";
    releaseCancel?.setAttribute("hidden", "");
  }

  function startReleaseEditor(release) {
    if (!(releaseForm instanceof HTMLFormElement)) return;
    releaseForm.setAttribute("data-editing-release", release.id);
    releaseForm.elements.catalog_number.value = release.catalog_number || "";
    releaseForm.elements.status.value = release.status || "published";
    releaseForm.elements.title.value = release.title || "";
    releaseForm.elements.artist_display.value = release.artist_display || "";
    releaseForm.elements.primary_artist_id.value = release.primary_artist_id || "";
    releaseForm.elements.genre.value = release.genre || "";
    releaseForm.elements.mbp_region.value = release.mbp_region || "world";
