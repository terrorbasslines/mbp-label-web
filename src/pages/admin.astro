  function renderRegionBadge(region) {
    const meta = regionMeta(region);
    return `<span class="inline-flex rounded border px-2 py-1 text-[0.68rem] font-black uppercase tracking-[0.14em]" style="border-color:${escapeHtml(meta.color)}66; color:${escapeHtml(meta.color)}">${escapeHtml(meta.label)}</span>`;
  }

  function renderLabelBadges(item) {
    return itemLabelDetails(item)
      .map((label) => `<span class="inline-flex rounded border px-2 py-1 text-[0.68rem] font-black uppercase tracking-[0.14em]" style="border-color:${escapeHtml(label.color)}66; color:${escapeHtml(label.color)}">${escapeHtml(label.shortName || label.label)}</span>`)
      .join("");
  }

  function labelMatches(item, selectedLabel) {
    return selectedLabel === "all" || hasLabel(item, selectedLabel);
  }

  function mbpRegionMatches(item, selectedRegion) {
    return selectedRegion === "all" || (hasLabel(item, "mbp") && String(item.mbp_region || "world").toLowerCase() === selectedRegion);
  }

  function syncLabelRegionFilters() {
    if (adminArtistRegion instanceof HTMLSelectElement) {
      const disableArtistRegion = artistLabelTerm !== "all" && artistLabelTerm !== "mbp";
      adminArtistRegion.disabled = disableArtistRegion;
      if (disableArtistRegion) {
        adminArtistRegion.value = "all";
        artistRegionTerm = "all";
      }
    }
    if (adminReleaseRegion instanceof HTMLSelectElement) {
      const disableReleaseRegion = releaseLabelTerm !== "all" && releaseLabelTerm !== "mbp";
      adminReleaseRegion.disabled = disableReleaseRegion;
      if (disableReleaseRegion) {
        adminReleaseRegion.value = "all";
        releaseRegionTerm = "all";
      }
    }
  }

  function filteredArtists() {
    const query = artistSearchTerm.trim().toLowerCase();
    const label = artistLabelTerm;
    const region = artistRegionTerm;
    return artists.filter((artist) =>
      labelMatches(artist, label) &&
      mbpRegionMatches(artist, region) &&
      (!query || searchableText([
        artist.name,
        artist.country,
        artist.profile,
        artist.claimed_email,
        artist.claimed_role,
        artist.mbp_region,
        regionMeta(artist.mbp_region).label,
        ...itemLabelDetails(artist).flatMap((item) => [item.label, item.shortName])
      ]).includes(query))
    );
  }

  function filteredReleases() {
    const query = releaseSearchTerm.trim().toLowerCase();
    const label = releaseLabelTerm;
    const region = releaseRegionTerm;
    return releases.filter((release) =>
      labelMatches(release, label) &&
      mbpRegionMatches(release, region) &&
      (!query || searchableText([
        release.catalog_number,
        release.title,
        release.artist_display,
        release.status,
        release.genre,
        release.description,
        release.mbp_region,
        regionMeta(release.mbp_region).label,
        ...itemLabelDetails(release).flatMap((item) => [item.label, item.shortName])
      ]).includes(query))
    );
  }

