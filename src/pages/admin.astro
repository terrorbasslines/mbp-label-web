---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<style is:global>
  .mbp-news-editor .ck.ck-editor {
    border-radius: 8px;
    overflow: hidden;
  }
  .mbp-news-editor .ck.ck-toolbar,
  .mbp-news-editor .ck.ck-editor__main > .ck-editor__editable {
    border-color: rgba(255, 255, 255, 0.14) !important;
    background: #050508 !important;
    color: #fff !important;
  }
  .mbp-news-editor .ck.ck-toolbar {
    border-bottom-color: rgba(255, 255, 255, 0.18) !important;
  }
  .mbp-news-editor .ck.ck-button,
  .mbp-news-editor .ck.ck-button .ck-icon,
  .mbp-news-editor .ck.ck-dropdown__button {
    color: #d6d8e2 !important;
  }
  .mbp-news-editor .ck.ck-button:hover,
  .mbp-news-editor .ck.ck-button.ck-on {
    background: rgba(34, 247, 255, 0.12) !important;
    color: #fff !important;
  }
  .mbp-news-editor .ck.ck-dropdown__panel,
  .mbp-news-editor .ck.ck-list {
    border-color: rgba(255, 255, 255, 0.18) !important;
    background: #08090f !important;
  }
  .mbp-news-editor .ck.ck-list__item .ck-button {
    background: #08090f !important;
    color: #f8f8fb !important;
  }
  .mbp-news-editor .ck.ck-list__item .ck-button .ck-button__label {
    color: #f8f8fb !important;
  }
  .mbp-news-editor .ck.ck-list__item .ck-button:hover,
  .mbp-news-editor .ck.ck-list__item .ck-button.ck-on {
    background: rgba(34, 247, 255, 0.16) !important;
    color: #fff !important;
  }
  .mbp-news-editor .ck-content figure {
    margin: 1.5rem 0;
  }
  .mbp-news-editor .ck-content img {
    max-width: 100%;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 8px;
  }
  .mbp-news-editor .ck-content .media,
  .mbp-news-editor .ck-content .media-embed {
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 8px;
    background: #000;
  }
  .mbp-news-editor .ck-content .media iframe,
  .mbp-news-editor .ck-content .media-embed iframe {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    border: 0;
  }
  .mbp-news-editor .ck-content video,
  .mbp-news-editor .ck-content audio {
    display: block;
    width: 100%;
  }
  .mbp-news-editor .ck-content video {
    aspect-ratio: 16 / 9;
    background: #000;
  }
  .mbp-news-editor .ck.ck-editor__editable {
    min-height: 360px;
    padding: 18px !important;
    font-size: 1rem;
    line-height: 1.8;
  }
</style>

<BaseLayout title="Admin" description="The MasterBeat Project admin dashboard." noindex={true}>
  <section class="border-b border-white/10 bg-black/50 py-16">
    <div class="section-shell">
      <p class="eyebrow">Backoffice</p>
      <h1 class="page-title mt-4">Admin</h1>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-haze">
        Manage artists, releases, platform links and incoming demo submissions.
      </p>
    </div>
  </section>

  <section class="py-10">
    <div class="section-shell">
      <div data-admin-app class="space-y-8">
        <form data-login-form class="surface mx-auto max-w-lg rounded-lg p-6">
          <p class="eyebrow">Login</p>
          <h2 class="mt-3 font-display text-3xl font-black uppercase text-white">Admin access</h2>
          <label class="mt-6 block">
            <span class="field-label">Password</span>
            <input class="field-control" name="password" type="password" required autocomplete="current-password" />
          </label>
          <button class="mt-5 inline-flex min-h-12 items-center justify-center rounded-md bg-white px-6 py-3 text-sm font-black uppercase tracking-[0.14em] text-black transition hover:bg-neon-cyan" type="submit">
            Login
          </button>
          <p class="mt-4 text-sm text-steel" data-login-status>Protected by Cloudflare env secrets.</p>
        </form>

        <div data-dashboard hidden class="space-y-8">
          <div class="flex flex-col gap-4 rounded-lg border border-white/10 bg-carbon/80 p-5 sm:flex-row sm:items-center sm:justify-between">
            <div>
              <p class="eyebrow">Dashboard</p>
              <h2 class="mt-2 font-display text-3xl font-black uppercase text-white">Label database</h2>
              <p class="mt-2 text-sm text-steel" data-dashboard-status>Loading dashboard data...</p>
            </div>
            <div class="flex flex-wrap gap-2">
              <button data-refresh class="rounded-md border border-white/10 px-4 py-2 text-sm font-bold text-haze hover:border-neon-cyan hover:text-white" type="button">Refresh</button>
              <button data-logout class="rounded-md bg-white px-4 py-2 text-sm font-black uppercase text-black hover:bg-neon-cyan" type="button">Logout</button>
            </div>
          </div>

          <div class="grid gap-5 sm:grid-cols-2 xl:grid-cols-6" data-stats></div>

          <section class="surface rounded-lg p-5">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
              <div>
                <p class="eyebrow">Release calendar</p>
                <h3 class="mt-2 font-display text-2xl font-black uppercase text-white">Label calendar</h3>
                <p class="mt-2 text-sm leading-6 text-steel">Plan MBP, MBH and S7 release windows with agreement, artwork, delivery and promo deadlines.</p>
              </div>
              <a class="inline-flex min-h-10 items-center justify-center rounded-md border border-white/10 px-4 py-2 text-xs font-black uppercase tracking-[0.14em] text-haze transition hover:border-neon-cyan hover:text-white" href="/admin/release-calendar/">
                Calendar import
              </a>
            </div>
            <form data-calendar-generate class="mt-5 grid gap-3 md:grid-cols-[1fr_1fr_1fr_1fr_auto]">
              <label>
                <span class="field-label">Brand</span>
                <select class="field-control" name="brand">
                  <option>MBP</option>
                  <option>MBH</option>
                  <option>S7</option>
                </select>
              </label>
              <label>
                <span class="field-label">From</span>
                <input class="field-control" name="from" type="date" required />
              </label>
              <label>
                <span class="field-label">To</span>
                <input class="field-control" name="to" type="date" required />
              </label>
              <label>
                <span class="field-label">Weekdays</span>
                <input class="field-control" name="weekdays" value="1,4" placeholder="1,4 = Monday, Thursday" />
              </label>
              <button class="self-end rounded-md bg-white px-4 py-3 text-sm font-black uppercase text-black hover:bg-neon-cyan" type="submit">
                Generate slots
              </button>
            </form>
            <form data-calendar-form class="mt-5 grid gap-3 md:grid-cols-4">
              <input name="id" type="hidden" />
              <label>
                <span class="field-label">Brand</span>
                <select class="field-control" name="brand">
                  <option>MBP</option>
                  <option>MBH</option>
                  <option>S7</option>
                </select>
              </label>
              <label>
                <span class="field-label">Release date</span>
                <input class="field-control" name="release_date" type="date" required />
              </label>
              <label>
                <span class="field-label">Status</span>
                <select class="field-control" name="status">
                  <option value="available">Available</option>
                  <option value="reserved">Reserved</option>
                  <option value="confirmed">Confirmed</option>
                  <option value="locked">Locked</option>
                  <option value="released">Released</option>
                  <option value="cancelled">Cancelled</option>
                </select>
              </label>
              <label>
                <span class="field-label">Max releases</span>
                <input class="field-control" name="max_releases" type="number" min="1" max="10" value="1" />
              </label>
              <label>
                <span class="field-label">Catalog number</span>
                <input class="field-control" name="catalog_number" placeholder="MBP250" />
              </label>
              <label>
                <span class="field-label">Artist</span>
                <input class="field-control" name="artist_name" placeholder="Artist name" />
              </label>
              <label>
                <span class="field-label">Track title</span>
                <input class="field-control" name="track_title" placeholder="Track title" />
              </label>
              <label>
                <span class="field-label">Internal notes</span>
                <input class="field-control" name="internal_notes" placeholder="Deadline notes or reserved context" />
              </label>
              <div class="flex flex-wrap gap-2 md:col-span-4">
                <button class="rounded-md bg-white px-4 py-3 text-sm font-black uppercase text-black hover:bg-neon-cyan" type="submit">
                  Save slot
                </button>
                <button class="rounded-md border border-white/10 px-4 py-3 text-sm font-bold uppercase text-haze hover:border-neon-cyan hover:text-white" data-calendar-cancel hidden type="button">
                  Cancel edit
                </button>
              </div>
              <p class="text-sm text-steel md:col-span-4" data-calendar-status></p>
            </form>
            <div class="mt-5 flex flex-col gap-3 rounded-md border border-white/10 bg-black/25 p-3 lg:flex-row lg:items-center lg:justify-between">
              <div class="flex flex-wrap gap-2" data-calendar-filter>
                <button class="rounded-md border border-white/10 bg-white px-3 py-2 text-xs font-bold uppercase text-black" data-calendar-brand="all" type="button">
                  All labels
                </button>
                <button class="rounded-md border border-white/10 px-3 py-2 text-xs font-bold uppercase text-haze hover:border-neon-cyan hover:text-white" data-calendar-brand="MBP" type="button">
                  MBP
                </button>
                <button class="rounded-md border border-white/10 px-3 py-2 text-xs font-bold uppercase text-haze hover:border-neon-cyan hover:text-white" data-calendar-brand="MBH" type="button">
                  MBH
                </button>
                <button class="rounded-md border border-white/10 px-3 py-2 text-xs font-bold uppercase text-haze hover:border-neon-cyan hover:text-white" data-calendar-brand="S7" type="button">
                  S7
                </button>
              </div>
              <div class="flex flex-wrap items-center gap-2">
                <button class="rounded-md border border-white/10 px-3 py-2 text-xs font-bold uppercase text-haze hover:border-neon-cyan hover:text-white disabled:cursor-not-allowed disabled:opacity-40" data-calendar-prev type="button">
                  Previous
                </button>
                <span class="min-w-36 text-center font-mono text-xs uppercase tracking-[0.16em] text-steel" data-calendar-page-label>Page 1 / 1</span>
                <button class="rounded-md border border-white/10 px-3 py-2 text-xs font-bold uppercase text-haze hover:border-neon-cyan hover:text-white disabled:cursor-not-allowed disabled:opacity-40" data-calendar-next type="button">
                  Next
                </button>
              </div>
            </div>
            <div class="mt-5 grid gap-3 md:grid-cols-2 xl:grid-cols-3" data-calendar-list></div>
          </section>

          <section class="surface rounded-lg p-5">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
              <div>
                <p class="eyebrow">Release agreements</p>
                <h3 class="mt-2 font-display text-2xl font-black uppercase text-white">Agreement portal</h3>
                <p class="mt-2 text-sm leading-6 text-steel">Turn approved demos into artist review, typed signature and label countersignature workflows.</p>
              </div>
            </div>
            <form data-agreement-form class="mt-5 grid gap-3 lg:grid-cols-[1fr_1fr_auto]">
              <label>
                <span class="field-label">Approved demo</span>
                <select class="field-control" name="demo_submission_id" data-agreement-demo-select required>
                  <option value="">Choose approved demo</option>
                </select>
              </label>
              <label>
                <span class="field-label">Calendar slot</span>
                <select class="field-control" name="calendar_slot_id" data-agreement-slot-select required>
                  <option value="">Choose calendar slot</option>
                </select>
              </label>
              <button class="self-end rounded-md bg-white px-4 py-3 text-sm font-black uppercase text-black hover:bg-neon-cyan" type="submit">
                Create agreement
              </button>
            </form>
            <p class="mt-3 text-sm text-steel" data-agreement-status></p>
            <div class="mt-5 grid gap-3 lg:grid-cols-2" data-agreement-list></div>
          </section>

          <section class="surface rounded-lg p-5">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
              <div>
                <p class="eyebrow">Demo inbox</p>
                <h3 class="mt-2 font-display text-2xl font-black uppercase text-white">Pending submissions</h3>
              </div>
              <a class="inline-flex min-h-10 items-center justify-center rounded-md border border-white/10 px-4 py-2 text-xs font-black uppercase tracking-[0.14em] text-haze transition hover:border-neon-cyan hover:text-white" href="/admin/demo-archive/">
                Archive demos
              </a>
            </div>
            <div class="mt-5 space-y-4" data-submissions-list></div>
          </section>

          <section class="surface rounded-lg p-5">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
              <div>
                <p class="eyebrow">News desk</p>
                <h3 class="mt-2 font-display text-2xl font-black uppercase text-white" data-news-form-title>Publish News article</h3>
                <p class="mt-2 text-sm leading-6 text-steel">Create official MBP articles with SEO metadata, category filters, rich article content and generated share thumbnails.</p>
              </div>
              <a class="inline-flex min-h-10 items-center justify-center rounded-md border border-white/10 px-4 py-2 text-xs font-black uppercase tracking-[0.14em] text-haze transition hover:border-neon-cyan hover:text-white" href="/news/">
                Open News
              </a>
            </div>
            <div class="mt-5 rounded-lg border border-white/10 bg-black/30 p-4">
              <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
                <div>
                  <p class="eyebrow">Categories</p>
                  <h4 class="mt-2 font-display text-xl font-black uppercase text-white" data-news-category-form-title>News categories</h4>
                </div>
                <button class="rounded-md border border-white/10 px-3 py-2 text-xs font-black uppercase tracking-[0.12em] text-haze hover:border-neon-cyan hover:text-white" data-news-category-cancel hidden type="button">Cancel edit</button>
              </div>
              <form data-news-category-form class="mt-4 grid gap-3 md:grid-cols-[1fr_1fr_auto]">
                <input name="id" type="hidden" />
                <label>
                  <span class="field-label">Category name</span>
                  <input class="field-control" name="name" maxlength="120" placeholder="Release Stories" required />
                </label>
                <label>
                  <span class="field-label">Slug</span>
                  <input class="field-control" name="slug" maxlength="120" placeholder="auto-generated if empty" />
                </label>
                <label>
                  <span class="field-label">Accent</span>
                  <input class="field-control min-h-12" name="accent_color" type="color" value="#bd00ff" />
                </label>
                <label class="md:col-span-3">
                  <span class="field-label">Description</span>
                  <input class="field-control" name="description" maxlength="500" placeholder="Short internal/public category context" />
                </label>
                <div class="md:col-span-3">
                  <button class="rounded-md bg-white px-4 py-3 text-sm font-black uppercase text-black hover:bg-neon-cyan" data-news-category-submit type="submit">Save category</button>
                </div>
                <p class="text-sm text-steel md:col-span-3" data-news-category-status></p>
              </form>
              <div class="mt-4 grid gap-3 md:grid-cols-2 xl:grid-cols-3" data-news-category-list></div>
            </div>
            <form data-news-form class="mt-5 grid gap-4 md:grid-cols-2" novalidate>
              <input name="id" type="hidden" data-news-edit-id />
              <label>
                <span class="field-label">Title</span>
                <input class="field-control" name="title" maxlength="180" required />
              </label>
              <label>
                <span class="field-label">Slug</span>
                <input class="field-control" name="slug" maxlength="160" placeholder="auto-generated if empty" />
              </label>
              <label>
                <span class="field-label">Status</span>
                <select class="field-control" name="status">
                  <option value="draft">Draft</option>
                  <option value="published">Published</option>
                </select>
              </label>
              <label>
                <span class="field-label">Category</span>
                <select class="field-control" name="category_id" data-news-category-select>
                  <option value="">Uncategorized</option>
                </select>
                <input name="category" type="hidden" />
              </label>
              <label>
                <span class="field-label">Author</span>
                <select class="field-control" name="author_name" data-news-author-select>
                  <option value="The MasterBeat Project">The MasterBeat Project</option>
                </select>
              </label>
              <label>
                <span class="field-label">Accent color</span>
                <input class="field-control min-h-12" name="accent_color" type="color" value="#bd00ff" />
              </label>
              <label>
                <span class="field-label">SEO title</span>
                <input class="field-control" name="seo_title" maxlength="180" placeholder="Search result headline" />
              </label>
              <label>
                <span class="field-label">SEO description</span>
                <input class="field-control" name="seo_description" maxlength="320" placeholder="Search result description" />
              </label>
              <label class="md:col-span-2">
                <span class="field-label">Cover image URL</span>
                <input class="field-control" name="cover_image_url" type="text" inputmode="url" placeholder="https://... or /media/news-images/..." />
              </label>
              <label class="md:col-span-2">
                <span class="field-label">Upload cover image</span>
                <input class="field-control" name="cover_image_upload" type="file" accept="image/*" />
                <span class="mt-2 block text-xs text-steel" data-news-upload-status>Optional. Uploaded covers are stored privately in Cloudflare R2 and served through the site.</span>
              </label>
              <label>
                <span class="field-label">Social title</span>
                <input class="field-control" name="social_title" maxlength="180" placeholder="Optional custom share headline" />
              </label>
              <label>
                <span class="field-label">Social description</span>
                <input class="field-control" name="social_description" maxlength="320" placeholder="Optional text for generated thumbnails" />
              </label>
              <label class="md:col-span-2">
                <span class="field-label">Excerpt</span>
                <textarea class="field-control min-h-20" name="excerpt" maxlength="500" placeholder="Short public summary for cards and SEO."></textarea>
              </label>
              <div class="md:col-span-2 mbp-news-editor">
                <span class="field-label">Article content</span>
                <div class="mb-3 flex flex-wrap gap-2">
                  <button class="rounded-md border border-white/10 px-3 py-2 text-xs font-black uppercase tracking-[0.12em] text-haze hover:border-neon-cyan hover:text-white" data-news-insert-media type="button">Embed link</button>
                  <button class="rounded-md border border-white/10 px-3 py-2 text-xs font-black uppercase tracking-[0.12em] text-haze hover:border-neon-cyan hover:text-white" data-news-insert-image type="button">Image URL</button>
                  <button class="rounded-md border border-white/10 px-3 py-2 text-xs font-black uppercase tracking-[0.12em] text-haze hover:border-neon-cyan hover:text-white" data-news-upload-media type="button">Upload media</button>
                  <input data-news-media-input type="file" accept="image/*,video/*,audio/*" hidden />
                </div>
                <textarea class="field-control min-h-52" name="content" data-news-editor placeholder="Write the article body here. The rich editor loads automatically when available."></textarea>
                <p class="mt-2 text-xs leading-5 text-steel" data-news-media-status>Use YouTube, SoundCloud, Spotify or Vimeo links for embeds. Upload images, audio or short video files when the article needs hosted media.</p>
              </div>
              <div class="flex flex-wrap gap-2 md:col-span-2">
                <button class="rounded-md bg-white px-4 py-3 text-sm font-black uppercase text-black hover:bg-neon-cyan" data-news-submit type="submit">Save article</button>
                <button class="rounded-md border border-white/10 px-4 py-3 text-sm font-bold uppercase text-haze hover:border-neon-cyan hover:text-white" data-news-cancel hidden type="button">Cancel edit</button>
              </div>
              <p class="text-sm text-steel md:col-span-2" data-news-form-status></p>
            </form>
            <div class="mt-6 space-y-3" data-news-list></div>
          </section>

          <section class="surface rounded-lg p-5">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
              <div>
                <p class="eyebrow">FFM import</p>
                <h3 class="mt-2 font-display text-2xl font-black uppercase text-white">Import label smartlinks</h3>
              </div>
              <form data-import-form class="flex flex-wrap items-end gap-3">
                <label>
                  <span class="field-label">Label</span>
                  <select class="field-control min-w-32" name="label">
                    <option value="mbp">MBP</option>
                    <option value="mbh">MBH</option>
                    <option value="s7">S7</option>
                  </select>
                </label>
                <label>
                  <span class="field-label">From</span>
                  <input class="field-control w-28" name="from" type="number" min="1" value="1" required />
                </label>
                <label>
                  <span class="field-label">To</span>
                  <input class="field-control w-28" name="to" type="number" min="1" max="1000" value="25" required />
                </label>
                <button class="mb-0.5 rounded-md bg-white px-4 py-3 text-sm font-black uppercase text-black hover:bg-neon-cyan" type="submit">Import</button>
              </form>
            </div>
            <p class="mt-3 text-sm text-steel" data-import-status>Imports MBP, MBH and S7 FFM links. MBH/S7 checks base, R and -R1 to -R10 remix suffixes per catalogue number.</p>
          </section>

          <div class="grid gap-8">
            <section class="surface rounded-lg p-5">
              <p class="eyebrow">Artists</p>
              <h3 class="mt-2 font-display text-2xl font-black uppercase text-white" data-artist-form-title>Add artist profile</h3>
              <form data-artist-form class="mt-5 grid gap-4">
                <input name="id" type="hidden" data-artist-edit-id />
                <label>
                  <span class="field-label">Name</span>
                  <input class="field-control" name="name" required />
                </label>
                <label>
                  <span class="field-label">Country</span>
                  <input class="field-control" name="country" />
                </label>
                <label>
                  <span class="field-label">MBP region</span>
                  <select class="field-control" name="mbp_region">
                    <option value="world">MBP World</option>
                    <option value="europe">MBP Europe</option>
                    <option value="america">MBP America</option>
                    <option value="asia">MBP Asia</option>
                    <option value="australia">MBP Australia</option>
                  </select>
                </label>
                <label>
                  <span class="field-label">Profile</span>
                  <textarea class="field-control min-h-28" name="profile"></textarea>
                </label>
                <label>
                  <span class="field-label">Image URL</span>
                  <input class="field-control" name="image_url" type="text" inputmode="url" />
                </label>
                <label>
                  <span class="field-label">Links, one per line: label|url</span>
                  <textarea class="field-control min-h-24" name="links"></textarea>
                </label>
                <label class="flex items-center gap-3 text-sm text-haze">
                  <input name="is_featured" type="checkbox" />
                  Featured artist
                </label>
                <div class="flex flex-wrap gap-2">
                  <button class="rounded-md bg-white px-4 py-3 text-sm font-black uppercase text-black hover:bg-neon-cyan" data-artist-submit type="submit">Save artist</button>
