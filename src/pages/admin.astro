  function resetNewsEditor() {
    if (!(newsForm instanceof HTMLFormElement)) return;
    newsForm.reset();
    newsForm.removeAttribute("data-editing-news");
    if (newsForm.elements.accent_color) newsForm.elements.accent_color.value = "#bd00ff";
