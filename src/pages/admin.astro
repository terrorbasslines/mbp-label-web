  function renderNewsArticles() {
    if (!newsList) return;
    const items = pageItems(newsArticles, "news");
    newsList.innerHTML = newsArticles.length
      ? items
          .map((article) => {
            const accent = newsAccent(article.accent_color);
            const publicPath = `/news/${encodeURIComponent(String(article.slug || "").toLowerCase())}`;
            const published = article.status === "published";
            return `
              <article class="rounded-md border bg-black/35 p-4" style="border-color:${escapeHtml(accent)}55;">
                <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                  <div class="min-w-0 flex-1">
                    <p class="font-mono text-xs font-bold uppercase tracking-[0.16em]" style="color:${escapeHtml(accent)};">${escapeHtml(article.status || "draft")} | ${escapeHtml(article.category || "News")}</p>
                    <h4 class="mt-2 font-display text-2xl font-black uppercase text-white">${escapeHtml(article.title)}</h4>
                    <p class="mt-1 text-sm text-steel">${escapeHtml(article.slug)} | ${escapeHtml(formatAdminDate(article.published_at || article.updated_at))} | ${Number(article.reactions_count || 0)} reactions | ${Number(article.comments_count || 0)} comments</p>
                    <p class="mt-3 text-sm leading-6 text-haze">${escapeHtml(article.excerpt || "No excerpt yet.")}</p>
                    <div class="mt-4 flex flex-wrap gap-2">
                      ${
