      { label: "Pending demos", value: submissionCounts.pending },
      { label: "Archive demos", value: submissionCounts.archived, href: "/admin/demo-archive/" }
    ];
    statsEl.innerHTML = items
      .map((item) => {
        const content = `<p class="font-display text-4xl font-black uppercase text-white">${item.value}</p><p class="mt-2 text-sm uppercase tracking-[0.14em] text-steel">${item.label}</p>`;
