  let artists = [];
  let releases = [];
  let submissions = [];
  let newsArticles = [];
  let newsCategories = [];
  let newsAuthors = [{ name: "The MasterBeat Project" }];
  let newsStats = { published: 0, draft: 0 };
  let calendarSlots = [];
  let calendarBrandFilter = "all";
  let calendarPage = 1;
  const calendarPageSize = 12;
  let agreements = [];
  let approvedDemos = [];
  let agreementSlots = [];
  let newsEditor = null;
  let newsEditorPromise = null;
  let artistSearchTerm = "";
  let releaseSearchTerm = "";
  let artistLabelTerm = "all";
  let artistRegionTerm = "all";
  let releaseLabelTerm = "all";
  let releaseRegionTerm = "all";
  let submissionCounts = { pending: 0, archived: 0, total: 0 };
  const pages = { artists: 1, releases: 1, submissions: 1, news: 1 };
  const pageSizes = { artists: 10, releases: 8, submissions: 5, news: 6 };
  const mbpRegions = {
    europe: { label: "MBP Europe", color: "#ffd000" },
    america: { label: "MBP America", color: "#23df1e" },
    asia: { label: "MBP Asia", color: "#ff1808" },
    world: { label: "MBP World", color: "#bd00ff" },
    australia: { label: "MBP Australia", color: "#1d27ff" }
  };
  const labelMeta = {
    mbp: { label: "The MasterBeat Project", shortName: "MBP", color: "#bd00ff" },
    mbh: { label: "The MasterBeat Horizon", shortName: "MBH", color: "#7eb7ff" },
    s7: { label: "Section 7", shortName: "S7", color: "#e7ff00" }
  };

  const escapeHtml = (value) =>
    String(value ?? "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#39;");

  function normalizeArtistUrl(value) {
    const text = String(value || "").trim().replace(/[)\],.]+$/g, "");
    if (!text) return null;
    if (/^https?:\/\//i.test(text)) return text;
    if (/^www\./i.test(text)) return `https://${text}`;
    if (/^[a-z0-9.-]+\.[a-z]{2,}(?:\/\S*)?$/i.test(text)) return `https://${text}`;
    return null;
  }

  function parseArtistLinks(value) {
    const lines = String(value || "")
      .split(/\r?\n/)
      .flatMap((line) => line.split(/\s*,\s*(?=(?:https?:\/\/|www\.|[a-z0-9.-]+\.[a-z]{2,}))/i))
      .map((line) => line.trim())
      .filter(Boolean);

    return lines
      .map((line, index) => {
        const match = line.match(/(?:https?:\/\/|www\.)[^\s<>"']+|[a-z0-9.-]+\.[a-z]{2,}(?:\/[^\s<>"']*)?/i);
        const url = normalizeArtistUrl(match?.[0] || line);
        if (!url) return null;
        const rawLabel = match?.index ? line.slice(0, match.index).replace(/[:|\-]+$/g, "").trim() : "";
        return { label: rawLabel || `Artist link ${index + 1}`, url };
      })
      .filter(Boolean);
  }

  function renderArtistLinks(value) {
    const links = parseArtistLinks(value);
    if (links.length) {
      return links
        .map(
          (link) =>
            `<a class="rounded border border-white/10 px-2 py-1 text-xs text-haze hover:border-neon-cyan hover:text-white" href="${escapeHtml(link.url)}" target="_blank" rel="noreferrer">${escapeHtml(link.label)}</a>`
        )
        .join("");
    }
    const text = String(value || "").trim();
    if (!text) return "";
    return `<details class="rounded border border-white/10 px-3 py-2 text-xs text-haze"><summary class="cursor-pointer font-bold uppercase">Artist links</summary><pre class="mt-2 whitespace-pre-wrap break-words font-sans text-xs leading-5 text-steel">${escapeHtml(text)}</pre></details>`;
  }

  const managementAdmins = new Set(["romee storm", "alexair", "rodrigo stadt"]);

  function formatFileSize(value) {
    const size = Number(value || 0);
    if (!size) return "";
    if (size < 1024 * 1024) return `${Math.round(size / 1024)} KB`;
    return `${(size / (1024 * 1024)).toFixed(1)} MB`;
  }

  function renderSubmissionMedia(submission) {
    const upload = submission.upload;
    if (upload?.playback_url && upload.is_audio) {
      return `
        <div class="mt-4 rounded-md border border-white/10 bg-black/35 p-3">
          <p class="text-xs font-bold uppercase tracking-[0.14em] text-steel">Uploaded audio ${upload.name ? `| ${escapeHtml(upload.name)}` : ""} ${upload.size ? `| ${escapeHtml(formatFileSize(upload.size))}` : ""}</p>
          <audio class="mt-3 w-full" controls preload="metadata" src="${escapeHtml(upload.playback_url)}"></audio>
        </div>
      `;
    }

    if (submission.streaming_link) {
      return `
        <div class="mt-4 rounded-md border border-white/10 bg-black/35 p-3">
          <p class="text-xs font-bold uppercase tracking-[0.14em] text-steel">Private streaming link${upload?.name ? ` | uploaded file: ${escapeHtml(upload.name)}` : ""}</p>
          <a class="mt-2 inline-flex rounded border border-white/10 px-3 py-2 text-xs font-bold uppercase text-haze hover:border-neon-cyan hover:text-white" href="${escapeHtml(submission.streaming_link)}" target="_blank" rel="noreferrer">Open private stream</a>
        </div>
      `;
    }

    if (upload?.name) {
      return `
        <div class="mt-4 rounded-md border border-white/10 bg-black/35 p-3">
          <p class="text-xs font-bold uppercase tracking-[0.14em] text-steel">Uploaded file</p>
          <p class="mt-2 text-sm text-haze">${escapeHtml(upload.name)}${upload.size ? ` | ${escapeHtml(formatFileSize(upload.size))}` : ""}</p>
          <p class="mt-1 text-xs text-steel">No audio player is shown because this upload is not an audio file.</p>
        </div>
      `;
    }

    return "";
  }

  async function api(path, options = {}) {
    const response = await fetch(path, {
      credentials: "same-origin",
      cache: "no-store",
      ...options,
      headers: {
        "content-type": "application/json",
        "cache-control": "no-cache",
        ...(options.headers ?? {})
      }
    });
    const data = await response.json().catch(() => ({ ok: false, error: "Invalid API response." }));
    if (!response.ok || data.ok === false) {
      throw new Error(data.error || `Request failed: ${response.status}`);
    }
    return data;
  }

  async function loadNewsEditor() {
    if (!newsEditorTextarea || newsEditor) return newsEditor;
    if (newsEditorPromise) return newsEditorPromise;
    newsEditorPromise = new Promise((resolve) => {
      const startEditor = async () => {
        try {
          if (!window.ClassicEditor) {
            resolve(null);
            return;
          }
          newsEditor = await window.ClassicEditor.create(newsEditorTextarea, {
            toolbar: [
              "heading",
              "|",
              "bold",
              "italic",
              "link",
              "bulletedList",
              "numberedList",
              "blockQuote",
              "mediaEmbed",
              "|",
              "undo",
              "redo"
            ],
            link: {
              defaultProtocol: "https://",
              decorators: {
                openInNewTab: {
                  mode: "manual",
                  label: "Open in new tab",
                  attributes: {
                    target: "_blank",
                    rel: "noopener noreferrer"
                  }
                }
              }
            },
            mediaEmbed: {
              previewsInData: false
            },
            heading: {
              options: [
                { model: "paragraph", title: "Paragraph", class: "ck-heading_paragraph" },
                { model: "heading2", view: "h2", title: "Section heading", class: "ck-heading_heading2" },
                { model: "heading3", view: "h3", title: "Subheading", class: "ck-heading_heading3" }
              ]
            }
          });
          resolve(newsEditor);
        } catch {
          resolve(null);
        }
      };

      if (window.ClassicEditor) {
        startEditor();
        return;
      }
      const script = document.createElement("script");
      script.src = "https://cdn.ckeditor.com/ckeditor5/41.4.2/classic/ckeditor.js";
      script.async = true;
      script.onload = startEditor;
      script.onerror = () => resolve(null);
      document.head.append(script);
    });
    return newsEditorPromise;
  }

  function getNewsContent() {
    if (newsEditor) return newsEditor.getData();
    return newsEditorTextarea?.value || "";
  }

  function getNewsPlainText(html) {
    const holder = document.createElement("div");
    holder.innerHTML = String(html || "");
    return (holder.textContent || "").replace(/\s+/g, " ").trim();
  }

  function setNewsBusy(isBusy, message = "") {
    if (newsSubmit instanceof HTMLButtonElement) newsSubmit.disabled = isBusy;
    if (newsFormStatus) {
      newsFormStatus.textContent = message;
      newsFormStatus.classList.toggle("text-neon-cyan", isBusy);
      newsFormStatus.classList.toggle("text-neon-red", false);
    }
  }

  function setNewsError(message) {
    if (newsFormStatus) {
      newsFormStatus.textContent = message;
      newsFormStatus.classList.remove("text-neon-cyan");
      newsFormStatus.classList.add("text-neon-red");
    }
  }

  function setNewsContent(value) {
    if (newsEditor) {
      newsEditor.setData(String(value || ""));
      return;
    }
    if (newsEditorTextarea) newsEditorTextarea.value = String(value || "");
  }

  function insertNewsHtml(html) {
    if (!html) return;
    if (newsEditor) {
      const viewFragment = newsEditor.data.processor.toView(html);
      const modelFragment = newsEditor.data.toModel(viewFragment);
      newsEditor.model.insertContent(modelFragment);
      return;
    }
    if (newsEditorTextarea) {
      const current = String(newsEditorTextarea.value || "").trim();
      newsEditorTextarea.value = current ? `${current}\n\n${html}` : html;
    }
  }

  function safeNewsUrl(value, allowRelative = false) {
    const url = String(value || "").trim();
    if (!url) return "";
    if (allowRelative && url.startsWith("/")) return url;
    try {
      const parsed = new URL(url);
      return parsed.protocol === "https:" ? parsed.toString() : "";
    } catch {
      return "";
    }
  }

  async function uploadNewsCover(file, articleId) {
    const formData = new FormData();
    formData.append("image", file);
    if (articleId) formData.append("article_id", articleId);
    const response = await fetch("/api/admin/news/image-upload", {
      method: "POST",
      credentials: "same-origin",
      body: formData
    });
    const data = await response.json().catch(() => ({ ok: false, error: "Invalid upload response." }));
    if (!response.ok || data.ok === false) throw new Error(data.error || `Upload failed: ${response.status}`);
    return data.url;
  }

  async function uploadNewsMedia(file, articleId) {
    const formData = new FormData();
    formData.append("media", file);
    if (articleId) formData.append("article_id", articleId);
    const response = await fetch("/api/admin/news/media-upload", {
      method: "POST",
      credentials: "same-origin",
      body: formData
    });
    const data = await response.json().catch(() => ({ ok: false, error: "Invalid upload response." }));
    if (!response.ok || data.ok === false) throw new Error(data.error || `Upload failed: ${response.status}`);
    return data;
  }

  function mediaHtml(url, type) {
    const safeUrl = safeNewsUrl(url, true);
    if (!safeUrl) return "";
    if (String(type || "").startsWith("image/")) {
      return `<figure class="image"><img src="${escapeHtml(safeUrl)}" alt="" /></figure>`;
    }
    if (String(type || "").startsWith("video/")) {
      return `<figure class="media-embed"><video controls preload="metadata" src="${escapeHtml(safeUrl)}"></video></figure>`;
    }
    if (String(type || "").startsWith("audio/")) {
      return `<figure class="media-embed"><audio controls src="${escapeHtml(safeUrl)}"></audio></figure>`;
    }
    return "";
  }

  function dispatchAuth(role = "admin") {
    window.dispatchEvent(new CustomEvent("mbp-auth-changed", { detail: { authenticated: true, role } }));
  }

  function pageItems(items, kind) {
    const totalPages = Math.max(1, Math.ceil(items.length / pageSizes[kind]));
    pages[kind] = Math.min(Math.max(1, pages[kind]), totalPages);
    const start = (pages[kind] - 1) * pageSizes[kind];
    return items.slice(start, start + pageSizes[kind]);
  }

  function renderPager(kind, total) {
    const totalPages = Math.max(1, Math.ceil(total / pageSizes[kind]));
    if (totalPages <= 1) return "";
    const start = (pages[kind] - 1) * pageSizes[kind] + 1;
    const end = Math.min(total, pages[kind] * pageSizes[kind]);
    return `
      <div class="mt-5 flex flex-col gap-3 rounded-md border border-white/10 bg-black/30 p-3 sm:flex-row sm:items-center sm:justify-between">
        <p class="text-xs uppercase tracking-[0.14em] text-steel">Showing ${start}-${end} of ${total}</p>
        <div class="flex gap-2">
          <button class="rounded border border-white/10 px-3 py-2 text-xs font-bold uppercase text-haze disabled:opacity-40" data-page-kind="${kind}" data-page-dir="-1" ${pages[kind] <= 1 ? "disabled" : ""} type="button">Previous</button>
          <span class="rounded border border-white/10 px-3 py-2 text-xs font-bold uppercase text-white">${pages[kind]} / ${totalPages}</span>
          <button class="rounded border border-white/10 px-3 py-2 text-xs font-bold uppercase text-haze disabled:opacity-40" data-page-kind="${kind}" data-page-dir="1" ${pages[kind] >= totalPages ? "disabled" : ""} type="button">Next</button>
        </div>
      </div>
    `;
  }

  function parseLinks(value) {
    return String(value ?? "")
      .split("\n")
      .map((line) => line.trim())
      .filter(Boolean)
      .map((line) => {
        const [label, url] = line.split("|").map((item) => item.trim());
        return { label, url };
      })
      .filter((link) => link.label && link.url);
  }

  function parsePlatformLinks(value) {
    return String(value ?? "")
      .split("\n")
      .map((line) => line.trim())
      .filter(Boolean)
      .map((line) => {
        const [platform, label, url] = line.split("|").map((item) => item.trim());
        return { platform, label: label || platform, url, is_playable: true };
      })
      .filter((link) => link.platform && link.url);
  }

  function linksToText(links) {
    return Array.isArray(links) ? links.map((link) => `${link.label || ""}|${link.url || ""}`).join("\n") : "";
  }

  function searchableText(values) {
    return values.filter(Boolean).join(" ").toLowerCase();
  }

  function regionMeta(region) {
    return mbpRegions[String(region || "").toLowerCase()] || mbpRegions.world;
  }

  function itemLabelKeys(item) {
    if (Array.isArray(item?.labels) && item.labels.length) {
      return item.labels.map((label) => String(label.key || "").toLowerCase()).filter(Boolean);
    }
    return [String(item?.release_label || "mbp").toLowerCase()];
  }

  function itemLabelDetails(item) {
    if (Array.isArray(item?.labels) && item.labels.length) {
      return item.labels.map((label) => ({
        key: String(label.key || "").toLowerCase(),
        label: label.name || label.label || labelMeta[String(label.key || "").toLowerCase()]?.label || "The MasterBeat Project",
        shortName: label.shortName || label.short_name || labelMeta[String(label.key || "").toLowerCase()]?.shortName || "MBP",
        color: label.color || labelMeta[String(label.key || "").toLowerCase()]?.color || "#bd00ff"
      }));
    }

    const key = String(item?.release_label || "mbp").toLowerCase();
    const fallback = labelMeta[key] || labelMeta.mbp;
    return [{
      key,
      label: item?.release_label_name || fallback.label,
      shortName: item?.release_label_short_name || fallback.shortName,
      color: item?.release_label_color || fallback.color
    }];
  }

  function hasLabel(item, label) {
    return itemLabelKeys(item).includes(label);
  }

  function formatAdminDate(value) {
    if (!value) return "No date";
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return String(value);
    return date.toLocaleDateString("en", { year: "numeric", month: "short", day: "numeric" });
  }

  function newsAccent(value) {
    return /^#[0-9a-f]{6}$/i.test(String(value || "")) ? String(value) : "#bd00ff";
  }

  function syncNewsCategoryHidden() {
    if (!(newsForm instanceof HTMLFormElement)) return;
    const selected = newsCategories.find((category) => category.id === newsForm.elements.category_id?.value);
    if (newsForm.elements.category) newsForm.elements.category.value = selected?.name || "";
    if (selected && newsForm.elements.accent_color && !newsForm.getAttribute("data-editing-news")) {
      newsForm.elements.accent_color.value = newsAccent(selected.accent_color);
    }
  }

  function renderNewsControls() {
    const authorNames = new Set(["The MasterBeat Project"]);
    for (const author of newsAuthors) {
      if (author?.name) authorNames.add(author.name);
    }
    for (const article of newsArticles) {
      if (article?.author_name) authorNames.add(article.author_name);
    }
    if (newsCategorySelect) {
      newsCategorySelect.innerHTML = `<option value="">Uncategorized</option>${newsCategories
        .map((category) => `<option value="${escapeHtml(category.id)}">${escapeHtml(category.name)}</option>`)
        .join("")}`;
    }
    if (newsAuthorSelect) {
      newsAuthorSelect.innerHTML = [...authorNames]
        .map((name) => `<option value="${escapeHtml(name)}">${escapeHtml(name)}</option>`)
        .join("");
    }
  }

