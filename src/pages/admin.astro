  function renderNewsArticles() {
    if (!newsList) return;
    const items = pageItems(newsArticles, "news");
    newsList.innerHTML = newsArticles.length
      ? items
          .map((article) => {
            const accent = newsAccent(article.accent_color);
            const publicPath = `/news/${encodeURIComponent(String(article.slug || "").toLowerCase())}`;
            const published = article.status === "published";
            const previewPath = `${publicPath}${published ? "" : "?preview=admin"}`;
            const thumbnailPreviewParam = published ? "" : "&preview=admin";
            return `
              <article class="rounded-md border bg-black/35 p-4" style="border-color:${escapeHtml(accent)}55;">
                <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                  <div class="min-w-0 flex-1">
                    <p class="font-mono text-xs font-bold uppercase tracking-[0.16em]" style="color:${escapeHtml(accent)};">${escapeHtml(article.status || "draft")} | ${escapeHtml(article.category || "News")}</p>
                    <h4 class="mt-2 font-display text-2xl font-black uppercase text-white">${escapeHtml(article.title)}</h4>
                    <p class="mt-1 text-sm text-steel">${escapeHtml(article.slug)} | ${escapeHtml(article.author_name || "The MasterBeat Project")} | ${escapeHtml(formatAdminDate(article.published_at || article.updated_at))} | ${Number(article.reactions_count || 0)} reactions | ${Number(article.comments_count || 0)} comments</p>
                    ${article.seo_title || article.seo_description ? `<p class="mt-2 text-xs leading-5 text-steel">SEO: ${escapeHtml(article.seo_title || article.title)}${article.seo_description ? ` | ${escapeHtml(article.seo_description)}` : ""}</p>` : ""}
                    <p class="mt-3 text-sm leading-6 text-haze">${escapeHtml(article.excerpt || "No excerpt yet.")}</p>
                    <div class="mt-4 flex flex-wrap gap-2">
                      <a class="rounded border border-white/10 px-2 py-1 text-xs text-haze hover:border-neon-cyan hover:text-white" href="${escapeHtml(previewPath)}" target="_blank" rel="noreferrer">${published ? "Open" : "Preview draft"}</a>
                      <a class="rounded border border-white/10 px-2 py-1 text-xs text-haze hover:border-neon-cyan hover:text-white" href="${escapeHtml(`${publicPath}/social-image.svg?platform=og${thumbnailPreviewParam}`)}" target="_blank" rel="noreferrer">Open Graph</a>
                      <a class="rounded border border-white/10 px-2 py-1 text-xs text-haze hover:border-neon-cyan hover:text-white" href="${escapeHtml(`${publicPath}/social-image.svg?platform=instagram-post${thumbnailPreviewParam}`)}" target="_blank" rel="noreferrer">Instagram Post</a>
                      <a class="rounded border border-white/10 px-2 py-1 text-xs text-haze hover:border-neon-cyan hover:text-white" href="${escapeHtml(`${publicPath}/social-image.svg?platform=instagram-story${thumbnailPreviewParam}`)}" target="_blank" rel="noreferrer">Instagram Story</a>
                    </div>
                  </div>
                  <div class="flex flex-wrap gap-2">
                    <button class="text-xs font-bold uppercase text-neon-cyan hover:text-white" data-edit-news="${escapeHtml(article.id)}" type="button">Edit</button>
                    <button class="text-xs font-bold uppercase text-neon-cyan hover:text-white" data-news-status="${escapeHtml(article.id)}" data-next-status="${published ? "draft" : "published"}" type="button">${published ? "Move to draft" : "Publish"}</button>
                    <button class="text-xs font-bold uppercase text-neon-cyan hover:text-white" data-delete-news="${escapeHtml(article.id)}" type="button">Delete</button>
                  </div>
                </div>
              </article>
            `;
          })
          .join("") + renderPager("news", newsArticles.length)
      : `<p class="text-sm text-steel">No News articles yet. Create the first MBP update above.</p>`;
  }

  const calendarBrandColors = { MBP: "#bd00ff", MBH: "#00e5ff", S7: "#ffd000" };

  function formatCalendarDate(value) {
    if (!value) return "No date";
    const date = new Date(`${value}T00:00:00`);
    return Number.isNaN(date.getTime()) ? value : date.toLocaleDateString(undefined, { year: "numeric", month: "short", day: "numeric" });
  }

  function slotLabel(slot) {
    const capacity = `${Number(slot.current_release_count || 0)}/${Number(slot.max_releases || 1)}`;
    return `${slot.brand || "MBP"} ${formatCalendarDate(slot.release_date)} | ${capacity} used${slot.catalog_number ? ` | ${slot.catalog_number}` : ""}`;
  }

  function resetCalendarEditor() {
    if (!(calendarForm instanceof HTMLFormElement)) return;
    calendarForm.reset();
    calendarForm.elements.id.value = "";
    calendarForm.elements.max_releases.value = "1";
    calendarCancel?.setAttribute("hidden", "");
  }

  function startCalendarEditor(slot) {
    if (!(calendarForm instanceof HTMLFormElement)) return;
    calendarForm.elements.id.value = slot.id || "";
    calendarForm.elements.brand.value = slot.brand || "MBP";
    calendarForm.elements.release_date.value = slot.release_date || "";
    calendarForm.elements.status.value = slot.status || "available";
    calendarForm.elements.max_releases.value = slot.max_releases || 1;
    calendarForm.elements.catalog_number.value = slot.catalog_number || "";
    calendarForm.elements.artist_name.value = slot.artist_name || "";
    calendarForm.elements.track_title.value = slot.track_title || "";
    calendarForm.elements.internal_notes.value = slot.internal_notes || "";
    calendarCancel?.removeAttribute("hidden");
    calendarForm.scrollIntoView({ behavior: "smooth", block: "center" });
  }

  function renderCalendar() {
    if (!calendarList) return;
    const filteredSlots =
      calendarBrandFilter === "all"
        ? calendarSlots
        : calendarSlots.filter((slot) => String(slot.brand || "MBP").toUpperCase() === calendarBrandFilter);
    const totalPages = Math.max(1, Math.ceil(filteredSlots.length / calendarPageSize));
    calendarPage = Math.min(Math.max(1, calendarPage), totalPages);
    const start = (calendarPage - 1) * calendarPageSize;
    const slots = filteredSlots.slice(start, start + calendarPageSize);

    calendarFilter?.querySelectorAll("[data-calendar-brand]").forEach((button) => {
      const active = button.getAttribute("data-calendar-brand") === calendarBrandFilter;
      button.classList.toggle("bg-white", active);
      button.classList.toggle("text-black", active);
      button.classList.toggle("text-haze", !active);
    });
    if (calendarPageLabel) {
      const label = calendarBrandFilter === "all" ? "All labels" : calendarBrandFilter;
      calendarPageLabel.textContent = `${label} | ${filteredSlots.length} slots | Page ${calendarPage} / ${totalPages}`;
    }
    if (calendarPrev instanceof HTMLButtonElement) calendarPrev.disabled = calendarPage <= 1;
    if (calendarNext instanceof HTMLButtonElement) calendarNext.disabled = calendarPage >= totalPages;

    calendarList.innerHTML = slots.length
      ? slots
          .map((slot) => {
            const color = calendarBrandColors[slot.brand] || calendarBrandColors.MBP;
            return `
              <article class="rounded-md border bg-black/35 p-4" style="border-color:${escapeHtml(color)}66;">
                <div class="flex items-start justify-between gap-3">
                  <div>
                    <p class="font-mono text-xs font-bold uppercase tracking-[0.16em]" style="color:${escapeHtml(color)};">${escapeHtml(slot.brand || "MBP")} | ${escapeHtml(slot.status || "available")}</p>
                    <h4 class="mt-2 font-display text-xl font-black uppercase text-white">${escapeHtml(formatCalendarDate(slot.release_date))}</h4>
                    <p class="mt-1 text-sm text-steel">${escapeHtml(slot.catalog_number || "No catalog")} ${slot.artist_name ? `| ${escapeHtml(slot.artist_name)}` : ""}</p>
                    <p class="mt-3 text-sm leading-6 text-haze">${escapeHtml(slot.track_title || slot.internal_notes || "Open release slot.")}</p>
                    <p class="mt-3 text-xs leading-5 text-steel">Occupancy ${escapeHtml(Number(slot.current_release_count || 0))}/${escapeHtml(Number(slot.max_releases || 1))} | Agreement ${escapeHtml(formatCalendarDate(slot.agreement_deadline))} | Assets ${escapeHtml(formatCalendarDate(slot.asset_deadline))} | Distributor ${escapeHtml(formatCalendarDate(slot.distributor_delivery_deadline))}</p>
                  </div>
                  <div class="flex shrink-0 gap-2">
                    <button class="text-xs font-bold uppercase text-neon-cyan hover:text-white" data-calendar-edit="${escapeHtml(slot.id)}" type="button">Edit</button>
                    <button class="text-xs font-bold uppercase text-neon-red hover:text-white" data-calendar-delete="${escapeHtml(slot.id)}" type="button">Delete</button>
                  </div>
                </div>
              </article>
            `;
          })
          .join("")
      : `<p class="text-sm text-steel">No release calendar slots for this label.</p>`;
  }

  function renderAgreements() {
    if (agreementDemoSelect) {
      agreementDemoSelect.innerHTML =
        `<option value="">Choose approved demo</option>` +
        approvedDemos
          .map((demo) => `<option value="${escapeHtml(demo.id)}">${escapeHtml(demo.track_title || "Untitled")} | ${escapeHtml(demo.artist_name || "Unknown artist")}</option>`)
          .join("");
    }
    if (agreementSlotSelect) {
      agreementSlotSelect.innerHTML =
        `<option value="">Choose calendar slot</option>` +
        agreementSlots
          .map((slot) => `<option value="${escapeHtml(slot.id)}">${escapeHtml(slotLabel(slot))}</option>`)
          .join("");
    }
    if (!agreementList) return;
    agreementList.innerHTML = agreements.length
      ? agreements
          .map((agreement) => {
            const color = calendarBrandColors[agreement.brand] || calendarBrandColors.MBP;
            const canSign = agreement.status === "waiting_label_signature";
            return `
              <article class="rounded-md border bg-black/35 p-4" style="border-color:${escapeHtml(color)}66;">
                <p class="font-mono text-xs font-bold uppercase tracking-[0.16em]" style="color:${escapeHtml(color)};">${escapeHtml(agreement.brand || "MBP")} | ${escapeHtml(agreement.status || "draft")}</p>
                <h4 class="mt-2 font-display text-xl font-black uppercase text-white">${escapeHtml(agreement.release_title || "Untitled release")}</h4>
                <p class="mt-1 text-sm text-steel">${escapeHtml(agreement.artist_name || "Unknown artist")} | ${escapeHtml(agreement.slot_catalog_number || agreement.catalog_number || "No catalog")} | ${escapeHtml(formatCalendarDate(agreement.planned_release_date || agreement.slot_release_date || agreement.release_date))}</p>
                <div class="mt-4 flex flex-wrap gap-2">
                  <button class="rounded border border-white/10 px-3 py-2 text-xs font-black uppercase text-haze hover:border-neon-cyan hover:text-white" data-agreement-artist-link="${escapeHtml(agreement.id)}" type="button">Artist link</button>
                  ${canSign ? `<button class="rounded border border-neon-green/50 px-3 py-2 text-xs font-black uppercase text-neon-green hover:bg-neon-green hover:text-black" data-agreement-sign-label="${escapeHtml(agreement.id)}" type="button">Label sign</button>` : ""}
                  <button class="rounded border border-white/10 px-3 py-2 text-xs font-black uppercase text-haze hover:border-neon-red hover:text-white" data-agreement-cancel="${escapeHtml(agreement.id)}" type="button">Cancel</button>
                </div>
              </article>
            `;
          })
          .join("")
      : `<p class="text-sm text-steel">No release agreements yet. Create one from an approved demo and a calendar slot.</p>`;
  }

  function render() {
    renderStats();
    renderNewsControls();
    renderNewsCategories();
    renderArtists();
    renderReleases();
    renderSubmissions();
    renderNewsArticles();
    renderCalendar();
    renderAgreements();
  }

  async function loadDashboard() {
    if (dashboardStatus) dashboardStatus.textContent = "Loading dashboard data...";
    const errors = [];
    const [artistResult, releaseResult, submissionResult, newsResult, calendarResult, agreementResult] = await Promise.allSettled([
      api("/api/admin/artists"),
      api("/api/admin/releases"),
      api("/api/admin/demo-submissions?scope=pending"),
      api("/api/admin/news"),
      api("/api/admin/calendar"),
      api("/api/admin/agreements")
    ]);

    if (artistResult.status === "fulfilled") {
      artists = artistResult.value.artists || [];
    } else {
      errors.push(`Artists: ${artistResult.reason?.message || "failed to load"}`);
    }

    if (releaseResult.status === "fulfilled") {
      releases = releaseResult.value.releases || [];
    } else {
      errors.push(`Releases: ${releaseResult.reason?.message || "failed to load"}`);
    }

    if (submissionResult.status === "fulfilled") {
      submissions = submissionResult.value.submissions || [];
      submissionCounts = submissionResult.value.counts || { pending: submissions.length, archived: 0, total: submissions.length };
    } else {
      errors.push(`Submissions: ${submissionResult.reason?.message || "failed to load"}`);
    }

    if (newsResult.status === "fulfilled") {
      newsArticles = newsResult.value.articles || [];
      newsCategories = newsResult.value.categories || [];
      newsAuthors = newsResult.value.authors && newsResult.value.authors.length ? newsResult.value.authors : [{ name: "The MasterBeat Project" }];
      newsStats = {
        published: Number(newsResult.value.stats?.published ?? newsArticles.filter((article) => article.status === "published").length),
        draft: Number(newsResult.value.stats?.draft ?? newsArticles.filter((article) => article.status !== "published").length)
      };
    } else {
      errors.push(`News: ${newsResult.reason?.message || "failed to load"}`);
    }

    if (calendarResult.status === "fulfilled") {
      calendarSlots = calendarResult.value.slots || [];
    } else {
      errors.push(`Calendar: ${calendarResult.reason?.message || "failed to load"}`);
    }

    if (agreementResult.status === "fulfilled") {
      agreements = agreementResult.value.agreements || [];
      approvedDemos = agreementResult.value.approved_demos || [];
      agreementSlots = agreementResult.value.slots || [];
    } else {
      errors.push(`Agreements: ${agreementResult.reason?.message || "failed to load"}`);
    }

    render();
    await loadNewsEditor().catch((error) => errors.push(`Editor: ${error.message}`));
    if (dashboardStatus) {
      dashboardStatus.textContent = errors.length ? `Dashboard loaded with issues: ${errors.join(" | ")}` : "Dashboard data loaded.";
    }
  }

  async function checkSession() {
    try {
      const session = await api("/api/admin/session", { method: "GET", headers: {} });
      if (session.authenticated) {
        dispatchAuth("admin");
        loginForm?.setAttribute("hidden", "");
        dashboard?.removeAttribute("hidden");
        await loadDashboard();
        return;
      }
      loginForm?.removeAttribute("hidden");
      dashboard?.setAttribute("hidden", "");
    } catch (error) {
      loginForm?.removeAttribute("hidden");
      dashboard?.setAttribute("hidden", "");
      if (loginStatus) loginStatus.textContent = error.message || "Admin session could not be checked.";
    }
  }

  loginForm?.addEventListener("submit", async (event) => {
    event.preventDefault();
    const formData = new FormData(loginForm);
    try {
      await api("/api/auth/login", { method: "POST", body: JSON.stringify({ password: formData.get("password") }) });
      dispatchAuth("admin");
      loginStatus.textContent = "Logged in.";
      loginForm.setAttribute("hidden", "");
      dashboard?.removeAttribute("hidden");
      await loadDashboard();
    } catch (error) {
      loginStatus.textContent = error.message;
    }
  });

  document.querySelector("[data-logout]")?.addEventListener("click", async () => {
    await api("/api/auth/logout", { method: "POST", body: "{}" });
    location.reload();
  });

  document.querySelector("[data-refresh]")?.addEventListener("click", loadDashboard);

  calendarGenerateForm?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!(calendarGenerateForm instanceof HTMLFormElement)) return;
    const formData = new FormData(calendarGenerateForm);
    if (calendarStatus) calendarStatus.textContent = "Generating release slots...";
    try {
      const generatedBrand = String(formData.get("brand") || "all").toUpperCase();
      const result = await api("/api/admin/calendar", {
        method: "POST",
        body: JSON.stringify({
          action: "generate_slots",
          brand: formData.get("brand"),
          from: formData.get("from"),
          to: formData.get("to"),
          weekdays: String(formData.get("weekdays") || "")
            .split(",")
            .map((day) => Number(day.trim()))
            .filter((day) => Number.isInteger(day) && day >= 0 && day <= 6)
        })
      });
      calendarBrandFilter = generatedBrand;
      calendarPage = 1;
      const source = result.source === "official_2026_calendar" ? "official calendar" : "weekday pattern";
      if (calendarStatus) {
        calendarStatus.textContent = `Generated ${result.created || 0} slots from ${source}. Removed ${result.removed || 0} empty non-release slots.`;
      }
      await loadDashboard();
    } catch (error) {
      if (calendarStatus) calendarStatus.textContent = error.message;
    }
  });

  calendarForm?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!(calendarForm instanceof HTMLFormElement)) return;
    const formData = new FormData(calendarForm);
    if (calendarStatus) calendarStatus.textContent = "Saving release slot...";
    try {
      await api("/api/admin/calendar", {
        method: "POST",
        body: JSON.stringify({
          id: formData.get("id"),
          brand: formData.get("brand"),
          release_date: formData.get("release_date"),
          status: formData.get("status"),
          max_releases: Number(formData.get("max_releases") || 1),
          catalog_number: formData.get("catalog_number"),
          artist_name: formData.get("artist_name"),
          track_title: formData.get("track_title"),
          internal_notes: formData.get("internal_notes")
        })
      });
      resetCalendarEditor();
      calendarBrandFilter = String(formData.get("brand") || "all").toUpperCase();
      calendarPage = 1;
      if (calendarStatus) calendarStatus.textContent = "Release slot saved.";
      await loadDashboard();
    } catch (error) {
      if (calendarStatus) calendarStatus.textContent = error.message;
    }
  });

  calendarCancel?.addEventListener("click", resetCalendarEditor);

  calendarFilter?.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof Element)) return;
    const button = target.closest("[data-calendar-brand]");
    if (!button) return;
    calendarBrandFilter = button.getAttribute("data-calendar-brand") || "all";
    calendarPage = 1;
    renderCalendar();
  });

  calendarPrev?.addEventListener("click", () => {
    calendarPage = Math.max(1, calendarPage - 1);
    renderCalendar();
  });

  calendarNext?.addEventListener("click", () => {
    calendarPage += 1;
    renderCalendar();
  });

  agreementForm?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!(agreementForm instanceof HTMLFormElement)) return;
    const formData = new FormData(agreementForm);
    if (agreementStatus) agreementStatus.textContent = "Creating agreement...";
    try {
      const result = await api("/api/admin/agreements", {
        method: "POST",
        body: JSON.stringify({
          demo_submission_id: formData.get("demo_submission_id"),
          calendar_slot_id: formData.get("calendar_slot_id")
        })
      });
      agreementForm.reset();
      const emailStatus = result.email?.status ? ` Email: ${result.email.status}.` : "";
      if (agreementStatus) {
        agreementStatus.innerHTML = `Agreement created for artist review.${escapeHtml(emailStatus)} ${
          result.review_url
            ? `<a class="text-neon-cyan hover:text-white" href="${escapeHtml(result.review_url)}" target="_blank" rel="noreferrer">Open artist link</a>`
            : ""
        }`;
      }
      await loadDashboard();
    } catch (error) {
      if (agreementStatus) agreementStatus.textContent = error.message;
    }
  });

  artistForm?.addEventListener("submit", async (event) => {
    event.preventDefault();
    const form = event.currentTarget;
    const formData = new FormData(form);
    const editingArtistId = form.getAttribute("data-editing-artist");
    await api(editingArtistId ? `/api/admin/artists/${editingArtistId}` : "/api/admin/artists", {
      method: editingArtistId ? "PUT" : "POST",
      body: JSON.stringify({
        name: formData.get("name"),
        country: formData.get("country"),
        profile: formData.get("profile"),
        image_url: formData.get("image_url"),
        links: parseLinks(formData.get("links")),
        mbp_region: formData.get("mbp_region"),
        is_featured: formData.get("is_featured") === "on"
      })
    });
    resetArtistEditor();
    await loadDashboard();
  });

  artistCancel?.addEventListener("click", resetArtistEditor);

  adminArtistSearch?.addEventListener("input", () => {
    artistSearchTerm = adminArtistSearch.value || "";
    pages.artists = 1;
    renderArtists();
  });

  adminArtistLabel?.addEventListener("change", () => {
    artistLabelTerm = adminArtistLabel.value || "all";
    syncLabelRegionFilters();
    pages.artists = 1;
    renderArtists();
  });

  adminArtistRegion?.addEventListener("change", () => {
    artistRegionTerm = adminArtistRegion.value || "all";
    pages.artists = 1;
    renderArtists();
  });

  adminReleaseSearch?.addEventListener("input", () => {
    releaseSearchTerm = adminReleaseSearch.value || "";
    pages.releases = 1;
    renderReleases();
  });

  adminReleaseLabel?.addEventListener("change", () => {
    releaseLabelTerm = adminReleaseLabel.value || "all";
    syncLabelRegionFilters();
    pages.releases = 1;
    renderReleases();
  });

  adminReleaseRegion?.addEventListener("change", () => {
    releaseRegionTerm = adminReleaseRegion.value || "all";
    pages.releases = 1;
    renderReleases();
  });

  newsCategorySelect?.addEventListener("change", syncNewsCategoryHidden);

  releaseForm?.addEventListener("submit", async (event) => {
    event.preventDefault();
    const form = event.currentTarget;
    const formData = new FormData(form);
    const editingReleaseId = form.getAttribute("data-editing-release");
    await api(editingReleaseId ? `/api/admin/releases/${editingReleaseId}` : "/api/admin/releases", {
      method: editingReleaseId ? "PUT" : "POST",
      body: JSON.stringify({
        catalog_number: formData.get("catalog_number"),
        title: formData.get("title"),
        artist_display: formData.get("artist_display"),
        primary_artist_id: formData.get("primary_artist_id"),
        release_date: formData.get("release_date"),
        genre: formData.get("genre"),
        artwork_url: formData.get("artwork_url"),
        ffm_url: formData.get("ffm_url"),
        presave_url: formData.get("ffm_url"),
        status: formData.get("status"),
        mbp_region: formData.get("mbp_region"),
        description: formData.get("description"),
        platform_links: parsePlatformLinks(formData.get("platform_links"))
      })
    });
    resetReleaseEditor();
    await loadDashboard();
  });

  releaseCancel?.addEventListener("click", resetReleaseEditor);

  newsForm?.addEventListener("submit", async (event) => {
    event.preventDefault();
    const form = event.currentTarget;
    if (!(form instanceof HTMLFormElement)) return;
    const formData = new FormData(form);
    const editingNewsId = form.getAttribute("data-editing-news");
    const contentHtml = getNewsContent();
    const title = String(formData.get("title") || "").trim();
    if (newsEditorTextarea) newsEditorTextarea.value = contentHtml;

    if (title.length < 2) {
      setNewsError("Article title is required.");
      form.elements.title?.focus();
      return;
    }
    if (getNewsPlainText(contentHtml).length < 10) {
      setNewsError("Article content is required before saving or publishing.");
      if (newsEditor) newsEditor.editing.view.focus();
      else newsEditorTextarea?.focus();
      return;
    }

    setNewsBusy(true, editingNewsId ? "Updating article..." : "Saving article...");
    try {
      const upload = formData.get("cover_image_upload");
      let coverImageUrl = formData.get("cover_image_url");
      if (upload instanceof File && upload.size > 0) {
        if (newsUploadStatus) newsUploadStatus.textContent = "Uploading cover image...";
        coverImageUrl = await uploadNewsCover(upload, editingNewsId || undefined);
        form.elements.cover_image_url.value = coverImageUrl;
        if (newsUploadStatus) newsUploadStatus.textContent = "Cover image uploaded.";
      }
      syncNewsCategoryHidden();
      const result = await api(editingNewsId ? `/api/admin/news/${editingNewsId}` : "/api/admin/news", {
        method: editingNewsId ? "PUT" : "POST",
        body: JSON.stringify({
          title,
          slug: formData.get("slug"),
          status: formData.get("status"),
          category_id: form.elements.category_id?.value,
          category: form.elements.category?.value,
          author_name: formData.get("author_name"),
          accent_color: formData.get("accent_color"),
          seo_title: formData.get("seo_title"),
          seo_description: formData.get("seo_description"),
          cover_image_url: coverImageUrl,
          social_title: formData.get("social_title"),
          social_description: formData.get("social_description"),
          excerpt: formData.get("excerpt"),
          content: contentHtml
        })
      });
      const emailStatus = result.email?.status && !String(result.email.status).startsWith("news_email_not_")
        ? ` Email: ${result.email.status}${Number.isFinite(result.email.recipient_count) ? ` (${result.email.recipient_count})` : ""}.`
        : "";
      setNewsBusy(false, `${editingNewsId ? "Article updated." : "Article saved."}${emailStatus}`);
      resetNewsEditor();
      pages.news = 1;
      await loadDashboard();
    } catch (error) {
      if (newsSubmit instanceof HTMLButtonElement) newsSubmit.disabled = false;
      setNewsError(error.message || "Article could not be saved.");
    }
  });

  newsCancel?.addEventListener("click", resetNewsEditor);

  newsInsertMedia?.addEventListener("click", async () => {
    await loadNewsEditor();
    const url = safeNewsUrl(window.prompt("Paste a YouTube, SoundCloud, Spotify or Vimeo link") || "");
    if (!url) return;
    insertNewsHtml(`<figure class="media"><oembed url="${escapeHtml(url)}"></oembed></figure>`);
  });

  newsInsertImage?.addEventListener("click", async () => {
    await loadNewsEditor();
    const url = safeNewsUrl(window.prompt("Paste an HTTPS image URL or site media path") || "", true);
    if (!url) return;
    insertNewsHtml(`<figure class="image"><img src="${escapeHtml(url)}" alt="" /></figure>`);
  });

  newsUploadMedia?.addEventListener("click", async () => {
    await loadNewsEditor();
    if (newsMediaInput instanceof HTMLInputElement) {
      newsMediaInput.value = "";
      newsMediaInput.click();
    }
  });

  newsMediaInput?.addEventListener("change", async () => {
    if (!(newsMediaInput instanceof HTMLInputElement)) return;
    const file = newsMediaInput.files?.[0];
    if (!file) return;
    const editingNewsId = newsForm?.getAttribute("data-editing-news") || "";
    if (newsMediaStatus) newsMediaStatus.textContent = "Uploading article media...";
    try {
      const media = await uploadNewsMedia(file, editingNewsId || undefined);
      const html = mediaHtml(media.url, media.type);
      if (!html) throw new Error("Uploaded media type cannot be inserted into the editor.");
      insertNewsHtml(html);
      if (newsMediaStatus) newsMediaStatus.textContent = "Media uploaded and inserted.";
    } catch (error) {
      if (newsMediaStatus) newsMediaStatus.textContent = error.message;
    }
  });

  newsCategoryCancel?.addEventListener("click", resetNewsCategoryEditor);

  newsCategoryForm?.addEventListener("submit", async (event) => {
    event.preventDefault();
    const form = event.currentTarget;
    const formData = new FormData(form);
    const editingCategoryId = form.getAttribute("data-editing-category");
    if (newsCategoryStatus) newsCategoryStatus.textContent = editingCategoryId ? "Updating category..." : "Saving category...";
    try {
      await api(editingCategoryId ? `/api/admin/news-categories/${editingCategoryId}` : "/api/admin/news-categories", {
        method: editingCategoryId ? "PUT" : "POST",
        body: JSON.stringify({
          name: formData.get("name"),
          slug: formData.get("slug"),
          description: formData.get("description"),
          accent_color: formData.get("accent_color")
        })
      });
      resetNewsCategoryEditor();
      if (newsCategoryStatus) newsCategoryStatus.textContent = "Category saved.";
      await loadDashboard();
    } catch (error) {
      if (newsCategoryStatus) newsCategoryStatus.textContent = error.message;
    }
  });

  document.querySelector("[data-import-form]")?.addEventListener("submit", async (event) => {
    event.preventDefault();
    const form = event.currentTarget;
    const formData = new FormData(form);
    importStatus.textContent = "Importing...";
    try {
      const result = await api("/api/admin/import-ffm", {
        method: "POST",
        body: JSON.stringify({ label: formData.get("label"), from: Number(formData.get("from")), to: Number(formData.get("to")) })
      });
      importStatus.textContent = `Imported ${result.imported.length}, skipped ${result.skipped.length}.`;
      await loadDashboard();
    } catch (error) {
      importStatus.textContent = error.message;
    }
  });

  document.addEventListener("click", async (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;
    const pager = target.closest("[data-page-kind]");
    if (pager) {
      const kind = pager.getAttribute("data-page-kind");
      const direction = Number(pager.getAttribute("data-page-dir"));
      if (kind && Number.isFinite(direction)) {
        pages[kind] += direction;
        render();
      }
      return;
    }

    const decisionButton = target.closest("[data-decision-button]");
    if (decisionButton) {
      const form = decisionButton.closest("[data-decision-form]");
      if (form) form.dataset.status = decisionButton.getAttribute("data-status") || decisionButton.getAttribute("value") || "";
    }

    const editArtistId = target.getAttribute("data-edit-artist");
    const artistId = target.getAttribute("data-delete-artist");
    const editReleaseId = target.getAttribute("data-edit-release");
    const releaseId = target.getAttribute("data-delete-release");
    const editNewsId = target.getAttribute("data-edit-news");
    const newsId = target.getAttribute("data-delete-news");
    const editNewsCategoryId = target.getAttribute("data-edit-news-category");
    const deleteNewsCategoryId = target.getAttribute("data-delete-news-category");
    const newsStatusId = target.getAttribute("data-news-status");
    const editCalendarId = target.getAttribute("data-calendar-edit");
    const deleteCalendarId = target.getAttribute("data-calendar-delete");
    const artistLinkAgreementId = target.getAttribute("data-agreement-artist-link");
    const signLabelAgreementId = target.getAttribute("data-agreement-sign-label");
    const cancelAgreementId = target.getAttribute("data-agreement-cancel");
    if (editCalendarId) {
      const slot = calendarSlots.find((item) => item.id === editCalendarId);
      if (slot) startCalendarEditor(slot);
      return;
    }
    if (deleteCalendarId) {
      if (!window.confirm("Delete this release calendar slot?")) return;
      await api("/api/admin/calendar", {
        method: "POST",
        body: JSON.stringify({ action: "delete_slot", id: deleteCalendarId })
      });
      resetCalendarEditor();
      await loadDashboard();
      return;
    }
    if (artistLinkAgreementId) {
      if (agreementStatus) agreementStatus.textContent = "Creating artist review link...";
      const result = await api(`/api/admin/agreements/${artistLinkAgreementId}`, {
        method: "POST",
        body: JSON.stringify({ action: "send_artist_link" })
      });
      if (agreementStatus) {
        agreementStatus.innerHTML = `Artist review link ready. Email: ${escapeHtml(result.email?.status || "not sent")}. <a class="text-neon-cyan hover:text-white" href="${escapeHtml(result.review_url)}" target="_blank" rel="noreferrer">Open link</a>`;
      }
      window.prompt("Artist review link", result.review_url);
      return;
    }
    if (signLabelAgreementId) {
      const signatureText = window.prompt("Type the label signer name to countersign this agreement:");
      if (!signatureText) return;
      await api(`/api/admin/agreements/${signLabelAgreementId}`, {
        method: "POST",
        body: JSON.stringify({ action: "sign_label", signature_text: signatureText })
      });
      await loadDashboard();
      return;
    }
    if (cancelAgreementId) {
      if (!window.confirm("Cancel this release agreement?")) return;
      await api(`/api/admin/agreements/${cancelAgreementId}`, {
        method: "POST",
        body: JSON.stringify({ action: "cancel" })
      });
      await loadDashboard();
      return;
    }
    if (editArtistId) {
      const artist = artists.find((item) => item.id === editArtistId);
      if (artist) startArtistEditor(artist);
      return;
    }
    if (artistId) {
      await api(`/api/admin/artists/${artistId}`, { method: "DELETE", body: "{}" });
      resetArtistEditor();
      await loadDashboard();
    }
    if (editReleaseId) {
      const release = releases.find((item) => item.id === editReleaseId);
      if (release) startReleaseEditor(release);
      return;
    }
    if (releaseId) {
      await api(`/api/admin/releases/${releaseId}`, { method: "DELETE", body: "{}" });
      resetReleaseEditor();
      await loadDashboard();
    }
    if (editNewsId) {
      const article = newsArticles.find((item) => item.id === editNewsId);
      if (article) startNewsEditor(article);
      return;
    }
    if (newsStatusId) {
      const article = newsArticles.find((item) => item.id === newsStatusId);
      const nextStatus = target.getAttribute("data-next-status") || "draft";
      if (!article) return;
      if (dashboardStatus) dashboardStatus.textContent = nextStatus === "published" ? "Publishing article..." : "Moving article to draft...";
      try {
        const result = await api(`/api/admin/news/${newsStatusId}`, {
          method: "PUT",
          body: JSON.stringify({
            title: article.title,
            slug: article.slug,
            status: nextStatus,
            category_id: article.category_id,
            category: article.category,
            author_name: article.author_name,
            accent_color: article.accent_color,
            seo_title: article.seo_title,
            seo_description: article.seo_description,
            cover_image_url: article.cover_image_url,
            social_title: article.social_title,
            social_description: article.social_description,
            excerpt: article.excerpt,
            content: article.content
          })
        });
        await loadDashboard();
        if (dashboardStatus) {
          const emailStatus = result.email?.status && !String(result.email.status).startsWith("news_email_not_")
            ? ` Email: ${result.email.status}${Number.isFinite(result.email.recipient_count) ? ` (${result.email.recipient_count})` : ""}.`
            : "";
          dashboardStatus.textContent = `Article ${nextStatus === "published" ? "published" : "moved to draft"}.${emailStatus}`;
        }
      } catch (error) {
        if (dashboardStatus) dashboardStatus.textContent = error.message || "Article status could not be changed.";
      }
      return;
    }
    if (newsId) {
      if (!window.confirm("Delete this News article?")) return;
      await api(`/api/admin/news/${newsId}`, { method: "DELETE", body: "{}" });
      resetNewsEditor();
      await loadDashboard();
      return;
    }
    if (editNewsCategoryId) {
      const category = newsCategories.find((item) => item.id === editNewsCategoryId);
      if (category) startNewsCategoryEditor(category);
      return;
    }
    if (deleteNewsCategoryId) {
      if (!window.confirm("Delete this News category? Existing articles will become uncategorized.")) return;
      await api(`/api/admin/news-categories/${deleteNewsCategoryId}`, { method: "DELETE", body: "{}" });
      resetNewsCategoryEditor();
      await loadDashboard();
    }
  });

  document.addEventListener("submit", async (event) => {
    const form = event.target;
    if (!(form instanceof HTMLFormElement)) return;
    const inviteArtistId = form.getAttribute("data-invite-form");
    if (inviteArtistId) {
      event.preventDefault();
      const statusEl = form.querySelector("[data-invite-status]");
      const formData = new FormData(form);
      if (statusEl) statusEl.textContent = "Creating invite...";
      try {
        const result = await api("/api/admin/artist-invites", {
          method: "POST",
          body: JSON.stringify({
            artist_id: inviteArtistId,
            email: formData.get("email"),
            role: formData.get("role")
          })
        });
        if (statusEl) statusEl.innerHTML = `Claim link (${escapeHtml(result.invite.role)}, ${escapeHtml(result.email?.status || "email not sent")}): <a class="text-neon-cyan hover:text-white" href="${escapeHtml(result.invite.claim_url)}" target="_blank" rel="noreferrer">${escapeHtml(result.invite.claim_url)}</a>`;
      } catch (error) {
        if (statusEl) statusEl.textContent = error.message;
      }
      return;
    }

    const submissionId = form.getAttribute("data-decision-form");
    if (!submissionId) return;
    event.preventDefault();
    const submitter = event.submitter;
    const formData = new FormData(form);
    const status = form.dataset.status || submitter?.getAttribute("data-status") || submitter?.getAttribute("value");
    const statusEl = form.querySelector("[data-decision-status]");
    const buttons = [...form.querySelectorAll("button")];
    if (!status) {
      if (statusEl) statusEl.textContent = "Missing decision status. Click Approve or Reject again.";
      return;
    }
    buttons.forEach((button) => (button.disabled = true));
    if (statusEl) statusEl.textContent = "Saving decision...";
    try {
      const result = await api(`/api/admin/demo-submissions/${submissionId}/decision`, {
        method: "POST",
        body: JSON.stringify({
          status,
          reason: formData.get("reason")
        })
      });
      if (statusEl) statusEl.textContent = result.email?.status || "Decision saved.";
      await loadDashboard();
    } catch (error) {
      if (statusEl) statusEl.textContent = error.message;
    } finally {
      buttons.forEach((button) => (button.disabled = false));
    }
  });

  syncLabelRegionFilters();
  checkSession();
</script>
