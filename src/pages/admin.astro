          .join("") + renderPager("news", newsArticles.length)
      : `<p class="text-sm text-steel">No News articles yet. Create the first MBP update above.</p>`;
  }

  function render() {
    renderStats();
    renderArtists();
    renderReleases();
    renderSubmissions();
    renderNewsArticles();
  }

  async function loadDashboard() {
    const [artistData, releaseData, submissionData, newsData] = await Promise.all([
      api("/api/admin/artists"),
      api("/api/admin/releases"),
      api("/api/admin/demo-submissions?scope=pending"),
      api("/api/admin/news")
    ]);
    artists = artistData.artists || [];
    releases = releaseData.releases || [];
    submissions = submissionData.submissions || [];
    newsArticles = newsData.articles || [];
    submissionCounts = submissionData.counts || { pending: submissions.length, archived: 0, total: submissions.length };
    render();
  }

  async function checkSession() {
    try {
      const session = await api("/api/admin/session", { method: "GET", headers: {} });
      if (session.authenticated) {
        dispatchAuth("admin");
        loginForm?.setAttribute("hidden", "");
        dashboard?.removeAttribute("hidden");
        await loadDashboard();
      }
    } catch {
      loginForm?.removeAttribute("hidden");
      dashboard?.setAttribute("hidden", "");
    }
  }

  loginForm?.addEventListener("submit", async (event) => {
    event.preventDefault();
    const formData = new FormData(loginForm);
    try {
      await api("/api/auth/login", { method: "POST", body: JSON.stringify({ password: formData.get("password") }) });
      dispatchAuth("admin");
      loginStatus.textContent = "Logged in.";
      loginForm.setAttribute("hidden", "");
      dashboard?.removeAttribute("hidden");
      await loadDashboard();
    } catch (error) {
      loginStatus.textContent = error.message;
    }
  });

  document.querySelector("[data-logout]")?.addEventListener("click", async () => {
    await api("/api/auth/logout", { method: "POST", body: "{}" });
    location.reload();
  });

  document.querySelector("[data-refresh]")?.addEventListener("click", loadDashboard);

  artistForm?.addEventListener("submit", async (event) => {
    event.preventDefault();
    const form = event.currentTarget;
    const formData = new FormData(form);
    const editingArtistId = form.getAttribute("data-editing-artist");
    await api(editingArtistId ? `/api/admin/artists/${editingArtistId}` : "/api/admin/artists", {
      method: editingArtistId ? "PUT" : "POST",
      body: JSON.stringify({
        name: formData.get("name"),
        country: formData.get("country"),
        profile: formData.get("profile"),
        image_url: formData.get("image_url"),
        links: parseLinks(formData.get("links")),
        mbp_region: formData.get("mbp_region"),
        is_featured: formData.get("is_featured") === "on"
      })
    });
    resetArtistEditor();
    await loadDashboard();
  });

  artistCancel?.addEventListener("click", resetArtistEditor);

  adminArtistSearch?.addEventListener("input", () => {
    artistSearchTerm = adminArtistSearch.value || "";
    pages.artists = 1;
    renderArtists();
  });

  adminArtistRegion?.addEventListener("change", () => {
    artistRegionTerm = adminArtistRegion.value || "all";
    pages.artists = 1;
    renderArtists();
  });

  adminReleaseSearch?.addEventListener("input", () => {
    releaseSearchTerm = adminReleaseSearch.value || "";
    pages.releases = 1;
    renderReleases();
  });

  adminReleaseRegion?.addEventListener("change", () => {
    releaseRegionTerm = adminReleaseRegion.value || "all";
    pages.releases = 1;
    renderReleases();
  });

  releaseForm?.addEventListener("submit", async (event) => {
    event.preventDefault();
    const form = event.currentTarget;
    const formData = new FormData(form);
    const editingReleaseId = form.getAttribute("data-editing-release");
    await api(editingReleaseId ? `/api/admin/releases/${editingReleaseId}` : "/api/admin/releases", {
      method: editingReleaseId ? "PUT" : "POST",
      body: JSON.stringify({
        catalog_number: formData.get("catalog_number"),
        title: formData.get("title"),
        artist_display: formData.get("artist_display"),
        primary_artist_id: formData.get("primary_artist_id"),
        release_date: formData.get("release_date"),
        genre: formData.get("genre"),
        artwork_url: formData.get("artwork_url"),
        ffm_url: formData.get("ffm_url"),
        presave_url: formData.get("ffm_url"),
        status: formData.get("status"),
        mbp_region: formData.get("mbp_region"),
        description: formData.get("description"),
        platform_links: parsePlatformLinks(formData.get("platform_links"))
      })
    });
    resetReleaseEditor();
    await loadDashboard();
  });

  releaseCancel?.addEventListener("click", resetReleaseEditor);

  newsForm?.addEventListener("submit", async (event) => {
    event.preventDefault();
    const form = event.currentTarget;
    const formData = new FormData(form);
    const editingNewsId = form.getAttribute("data-editing-news");
    await api(editingNewsId ? `/api/admin/news/${editingNewsId}` : "/api/admin/news", {
      method: editingNewsId ? "PUT" : "POST",
      body: JSON.stringify({
        title: formData.get("title"),
        slug: formData.get("slug"),
        status: formData.get("status"),
        category: formData.get("category"),
        author_name: formData.get("author_name"),
        accent_color: formData.get("accent_color"),
        cover_image_url: formData.get("cover_image_url"),
        social_title: formData.get("social_title"),
        social_description: formData.get("social_description"),
        excerpt: formData.get("excerpt"),
        content: formData.get("content")
      })
    });
    resetNewsEditor();
    pages.news = 1;
    await loadDashboard();
  });

  newsCancel?.addEventListener("click", resetNewsEditor);

  document.querySelector("[data-import-form]")?.addEventListener("submit", async (event) => {
    event.preventDefault();
    const form = event.currentTarget;
    const formData = new FormData(form);
    importStatus.textContent = "Importing...";
    try {
      const result = await api("/api/admin/import-ffm", {
        method: "POST",
        body: JSON.stringify({ from: Number(formData.get("from")), to: Number(formData.get("to")) })
      });
      importStatus.textContent = `Imported ${result.imported.length}, skipped ${result.skipped.length}.`;
      await loadDashboard();
    } catch (error) {
      importStatus.textContent = error.message;
    }
  });

  document.addEventListener("click", async (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;
    const pager = target.closest("[data-page-kind]");
    if (pager) {
      const kind = pager.getAttribute("data-page-kind");
      const direction = Number(pager.getAttribute("data-page-dir"));
      if (kind && Number.isFinite(direction)) {
        pages[kind] += direction;
        render();
      }
      return;
    }

    const decisionButton = target.closest("[data-decision-button]");
    if (decisionButton) {
      const form = decisionButton.closest("[data-decision-form]");
      if (form) form.dataset.status = decisionButton.getAttribute("data-status") || decisionButton.getAttribute("value") || "";
    }

    const editArtistId = target.getAttribute("data-edit-artist");
    const artistId = target.getAttribute("data-delete-artist");
    const editReleaseId = target.getAttribute("data-edit-release");
    const releaseId = target.getAttribute("data-delete-release");
    const editNewsId = target.getAttribute("data-edit-news");
    const newsId = target.getAttribute("data-delete-news");
    if (editArtistId) {
      const artist = artists.find((item) => item.id === editArtistId);
      if (artist) startArtistEditor(artist);
      return;
    }
    if (artistId) {
      await api(`/api/admin/artists/${artistId}`, { method: "DELETE", body: "{}" });
      resetArtistEditor();
      await loadDashboard();
    }
    if (editReleaseId) {
      const release = releases.find((item) => item.id === editReleaseId);
      if (release) startReleaseEditor(release);
      return;
    }
    if (releaseId) {
      await api(`/api/admin/releases/${releaseId}`, { method: "DELETE", body: "{}" });
      resetReleaseEditor();
      await loadDashboard();
    }
    if (editNewsId) {
      const article = newsArticles.find((item) => item.id === editNewsId);
      if (article) startNewsEditor(article);
      return;
    }
    if (newsId) {
      if (!window.confirm("Delete this News article?")) return;
      await api(`/api/admin/news/${newsId}`, { method: "DELETE", body: "{}" });
      resetNewsEditor();
      await loadDashboard();
    }
  });

  document.addEventListener("submit", async (event) => {
    const form = event.target;
    if (!(form instanceof HTMLFormElement)) return;
    const inviteArtistId = form.getAttribute("data-invite-form");
    if (inviteArtistId) {
      event.preventDefault();
      const statusEl = form.querySelector("[data-invite-status]");
      const formData = new FormData(form);
      if (statusEl) statusEl.textContent = "Creating invite...";
      try {
        const result = await api("/api/admin/artist-invites", {
          method: "POST",
          body: JSON.stringify({
            artist_id: inviteArtistId,
            email: formData.get("email"),
            role: formData.get("role")
          })
        });
        if (statusEl) statusEl.innerHTML = `Claim link (${escapeHtml(result.invite.role)}, ${escapeHtml(result.email?.status || "email not sent")}): <a class="text-neon-cyan hover:text-white" href="${escapeHtml(result.invite.claim_url)}" target="_blank" rel="noreferrer">${escapeHtml(result.invite.claim_url)}</a>`;
      } catch (error) {
        if (statusEl) statusEl.textContent = error.message;
      }
      return;
    }

    const submissionId = form.getAttribute("data-decision-form");
    if (!submissionId) return;
    event.preventDefault();
    const submitter = event.submitter;
    const formData = new FormData(form);
    const status = form.dataset.status || submitter?.getAttribute("data-status") || submitter?.getAttribute("value");
    const statusEl = form.querySelector("[data-decision-status]");
    const buttons = [...form.querySelectorAll("button")];
    if (!status) {
      if (statusEl) statusEl.textContent = "Missing decision status. Click Approve or Reject again.";
      return;
    }
    buttons.forEach((button) => (button.disabled = true));
    if (statusEl) statusEl.textContent = "Saving decision...";
    try {
      const result = await api(`/api/admin/demo-submissions/${submissionId}/decision`, {
        method: "POST",
        body: JSON.stringify({
          status,
          reason: formData.get("reason")
        })
      });
      if (statusEl) statusEl.textContent = result.email?.status || "Decision saved.";
      await loadDashboard();
    } catch (error) {
      if (statusEl) statusEl.textContent = error.message;
    } finally {
      buttons.forEach((button) => (button.disabled = false));
    }
  });

  checkSession();
</script>
