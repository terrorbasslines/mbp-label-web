---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Admin" description="The MasterBeat Project admin dashboard." noindex={true}>
  <section class="border-b border-white/10 bg-black/50 py-16">
    <div class="section-shell">
      <p class="eyebrow">Backoffice</p>
      <h1 class="page-title mt-4">Admin</h1>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-haze">
        Manage artists, releases, platform links and incoming demo submissions.
      </p>
    </div>
  </section>

  <section class="py-10">
    <div class="section-shell">
      <div data-admin-app class="space-y-8">
        <form data-login-form class="surface mx-auto max-w-lg rounded-lg p-6">
          <p class="eyebrow">Login</p>
          <h2 class="mt-3 font-display text-3xl font-black uppercase text-white">Admin access</h2>
          <label class="mt-6 block">
            <span class="field-label">Password</span>
            <input class="field-control" name="password" type="password" required autocomplete="current-password" />
          </label>
          <button class="mt-5 inline-flex min-h-12 items-center justify-center rounded-md bg-white px-6 py-3 text-sm font-black uppercase tracking-[0.14em] text-black transition hover:bg-neon-cyan" type="submit">
            Login
          </button>
          <p class="mt-4 text-sm text-steel" data-login-status>Protected by Cloudflare env secrets.</p>
        </form>

        <div data-dashboard hidden class="space-y-8">
          <div class="flex flex-col gap-4 rounded-lg border border-white/10 bg-carbon/80 p-5 sm:flex-row sm:items-center sm:justify-between">
            <div>
              <p class="eyebrow">Dashboard</p>
              <h2 class="mt-2 font-display text-3xl font-black uppercase text-white">Label database</h2>
            </div>
            <div class="flex flex-wrap gap-2">
              <button data-refresh class="rounded-md border border-white/10 px-4 py-2 text-sm font-bold text-haze hover:border-neon-cyan hover:text-white" type="button">Refresh</button>
              <button data-logout class="rounded-md bg-white px-4 py-2 text-sm font-black uppercase text-black hover:bg-neon-cyan" type="button">Logout</button>
            </div>
          </div>

          <div class="grid gap-5 lg:grid-cols-5" data-stats></div>

          <section class="surface rounded-lg p-5">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
              <div>
                <p class="eyebrow">Demo inbox</p>
                <h3 class="mt-2 font-display text-2xl font-black uppercase text-white">Pending submissions</h3>
              </div>
              <a class="inline-flex min-h-10 items-center justify-center rounded-md border border-white/10 px-4 py-2 text-xs font-black uppercase tracking-[0.14em] text-haze transition hover:border-neon-cyan hover:text-white" href="/admin/demo-archive/">
                Archive demos
              </a>
            </div>
            <div class="mt-5 space-y-4" data-submissions-list></div>
          </section>

          <section class="surface rounded-lg p-5">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
              <div>
                <p class="eyebrow">News desk</p>
                <h3 class="mt-2 font-display text-2xl font-black uppercase text-white" data-news-form-title>Publish News article</h3>
                <p class="mt-2 text-sm leading-6 text-steel">Create official MBP articles with generated share thumbnails for Open Graph, square posts and stories.</p>
              </div>
              <a class="inline-flex min-h-10 items-center justify-center rounded-md border border-white/10 px-4 py-2 text-xs font-black uppercase tracking-[0.14em] text-haze transition hover:border-neon-cyan hover:text-white" href="/news/">
                Open News
              </a>
            </div>
            <form data-news-form class="mt-5 grid gap-4 md:grid-cols-2">
              <input name="id" type="hidden" data-news-edit-id />
              <label>
                <span class="field-label">Title</span>
                <input class="field-control" name="title" maxlength="180" required />
              </label>
              <label>
                <span class="field-label">Slug</span>
                <input class="field-control" name="slug" maxlength="160" placeholder="auto-generated if empty" />
              </label>
              <label>
                <span class="field-label">Status</span>
                <select class="field-control" name="status">
                  <option value="draft">Draft</option>
                  <option value="published">Published</option>
                </select>
              </label>
              <label>
                <span class="field-label">Category</span>
                <input class="field-control" name="category" maxlength="120" placeholder="Label news" />
              </label>
              <label>
                <span class="field-label">Author</span>
                <input class="field-control" name="author_name" maxlength="160" placeholder="The MasterBeat Project" />
              </label>
              <label>
                <span class="field-label">Accent color</span>
                <input class="field-control min-h-12" name="accent_color" type="color" value="#bd00ff" />
              </label>
              <label class="md:col-span-2">
                <span class="field-label">Cover image URL</span>
                <input class="field-control" name="cover_image_url" type="url" placeholder="https://..." />
              </label>
              <label>
                <span class="field-label">Social title</span>
                <input class="field-control" name="social_title" maxlength="180" placeholder="Optional custom share headline" />
              </label>
              <label>
                <span class="field-label">Social description</span>
                <input class="field-control" name="social_description" maxlength="320" placeholder="Optional text for generated thumbnails" />
              </label>
              <label class="md:col-span-2">
                <span class="field-label">Excerpt</span>
                <textarea class="field-control min-h-20" name="excerpt" maxlength="500" placeholder="Short public summary for cards and SEO."></textarea>
              </label>
              <label class="md:col-span-2">
                <span class="field-label">Article content</span>
                <textarea class="field-control min-h-52" name="content" required placeholder="Write paragraphs separated by blank lines. Use lines starting with ## for section headings."></textarea>
              </label>
              <div class="flex flex-wrap gap-2 md:col-span-2">
                <button class="rounded-md bg-white px-4 py-3 text-sm font-black uppercase text-black hover:bg-neon-cyan" data-news-submit type="submit">Save article</button>
                <button class="rounded-md border border-white/10 px-4 py-3 text-sm font-bold uppercase text-haze hover:border-neon-cyan hover:text-white" data-news-cancel hidden type="button">Cancel edit</button>
              </div>
            </form>
            <div class="mt-6 space-y-3" data-news-list></div>
          </section>

          <section class="surface rounded-lg p-5">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
              <div>
                <p class="eyebrow">FFM import</p>
                <h3 class="mt-2 font-display text-2xl font-black uppercase text-white">Import MBP smartlinks</h3>
              </div>
              <form data-import-form class="flex flex-wrap items-end gap-3">
                <label>
                  <span class="field-label">From</span>
                  <input class="field-control w-28" name="from" type="number" min="1" value="1" required />
                </label>
                <label>
                  <span class="field-label">To</span>
                  <input class="field-control w-28" name="to" type="number" min="1" max="1000" value="25" required />
                </label>
                <button class="mb-0.5 rounded-md bg-white px-4 py-3 text-sm font-black uppercase text-black hover:bg-neon-cyan" type="submit">Import</button>
              </form>
            </div>
            <p class="mt-3 text-sm text-steel" data-import-status>Imports https://ffm.to/mbp001 to https://ffm.to/mbp1000 style links in batches of 25 max.</p>
          </section>

          <div class="grid gap-8 xl:grid-cols-[0.9fr_1.1fr]">
            <section class="surface rounded-lg p-5">
              <p class="eyebrow">Artists</p>
              <h3 class="mt-2 font-display text-2xl font-black uppercase text-white" data-artist-form-title>Add artist profile</h3>
              <form data-artist-form class="mt-5 grid gap-4">
                <input name="id" type="hidden" data-artist-edit-id />
                <label>
                  <span class="field-label">Name</span>
                  <input class="field-control" name="name" required />
                </label>
                <label>
                  <span class="field-label">Country</span>
                  <input class="field-control" name="country" />
                </label>
                <label>
                  <span class="field-label">MBP region</span>
                  <select class="field-control" name="mbp_region">
                    <option value="world">MBP World</option>
                    <option value="europe">MBP Europe</option>
                    <option value="america">MBP America</option>
                    <option value="asia">MBP Asia</option>
                    <option value="australia">MBP Australia</option>
                  </select>
                </label>
                <label>
                  <span class="field-label">Profile</span>
                  <textarea class="field-control min-h-28" name="profile"></textarea>
                </label>
                <label>
                  <span class="field-label">Image URL</span>
                  <input class="field-control" name="image_url" type="text" inputmode="url" />
                </label>
                <label>
                  <span class="field-label">Links, one per line: label|url</span>
                  <textarea class="field-control min-h-24" name="links"></textarea>
                </label>
                <label class="flex items-center gap-3 text-sm text-haze">
                  <input name="is_featured" type="checkbox" />
                  Featured artist
                </label>
                <div class="flex flex-wrap gap-2">
                  <button class="rounded-md bg-white px-4 py-3 text-sm font-black uppercase text-black hover:bg-neon-cyan" data-artist-submit type="submit">Save artist</button>
                  <button class="rounded-md border border-white/10 px-4 py-3 text-sm font-bold uppercase text-haze hover:border-neon-cyan hover:text-white" data-artist-cancel hidden type="button">Cancel edit</button>
                </div>
              </form>
              <div class="mt-6 grid gap-3 md:grid-cols-[1fr_auto] md:items-end">
                <label>
                  <span class="field-label">Search artists</span>
                  <input class="field-control" data-admin-artist-search type="search" placeholder="Search artist, country, role or profile" />
                </label>
                <label>
                  <span class="field-label">Region</span>
                  <select class="field-control min-w-44" data-admin-artist-region>
                    <option value="all">All MBP</option>
                    <option value="europe">MBP Europe</option>
                    <option value="america">MBP America</option>
                    <option value="asia">MBP Asia</option>
                    <option value="world">MBP World</option>
                    <option value="australia">MBP Australia</option>
                  </select>
                </label>
              </div>
              <div class="mt-6 space-y-3" data-artists-list></div>
            </section>

            <section class="surface rounded-lg p-5">
              <p class="eyebrow">Releases</p>
              <h3 class="mt-2 font-display text-2xl font-black uppercase text-white" data-release-form-title>Add catalogue item</h3>
              <form data-release-form class="mt-5 grid gap-4 md:grid-cols-2">
                <input name="id" type="hidden" data-release-edit-id />
                <label>
                  <span class="field-label">Catalog number</span>
                  <input class="field-control" name="catalog_number" placeholder="MBP001" required />
                </label>
                <label>
                  <span class="field-label">Status</span>
                  <select class="field-control" name="status">
                    <option value="published">Published</option>
                    <option value="presave">Pre-save</option>
                    <option value="draft">Draft</option>
                  </select>
                </label>
                <label>
                  <span class="field-label">Track title</span>
                  <input class="field-control" name="title" required />
                </label>
                <label>
                  <span class="field-label">Artist display</span>
                  <input class="field-control" name="artist_display" required />
                </label>
                <label>
                  <span class="field-label">Primary artist</span>
                  <select class="field-control" name="primary_artist_id" data-artist-select>
                    <option value="">No linked artist</option>
                  </select>
                </label>
                <label>
                  <span class="field-label">Genre</span>
                  <input class="field-control" name="genre" />
                </label>
                <label>
                  <span class="field-label">MBP region</span>
                  <select class="field-control" name="mbp_region">
                    <option value="world">MBP World</option>
                    <option value="europe">MBP Europe</option>
                    <option value="america">MBP America</option>
                    <option value="asia">MBP Asia</option>
                    <option value="australia">MBP Australia</option>
                  </select>
                </label>
                <label>
                  <span class="field-label">Release date</span>
                  <input class="field-control" name="release_date" type="date" />
                </label>
                <label>
                  <span class="field-label">FFM / pre-save URL</span>
                  <input class="field-control" name="ffm_url" type="url" placeholder="https://ffm.to/mbp001" />
                </label>
                <label class="md:col-span-2">
                  <span class="field-label">Artwork URL</span>
                  <input class="field-control" name="artwork_url" type="url" />
                </label>
                <label class="md:col-span-2">
                  <span class="field-label">Description</span>
                  <textarea class="field-control min-h-24" name="description"></textarea>
                </label>
                <label class="md:col-span-2">
                  <span class="field-label">Platform links, one per line: platform|label|url</span>
                  <textarea class="field-control min-h-28" name="platform_links" placeholder="spotify|Spotify|https://open.spotify.com/..."></textarea>
                </label>
                <div class="flex flex-wrap gap-2 md:col-span-2">
                  <button class="rounded-md bg-white px-4 py-3 text-sm font-black uppercase text-black hover:bg-neon-cyan" data-release-submit type="submit">Save release</button>
                  <button class="rounded-md border border-white/10 px-4 py-3 text-sm font-bold uppercase text-haze hover:border-neon-cyan hover:text-white" data-release-cancel hidden type="button">Cancel edit</button>
                </div>
              </form>
            </section>
          </div>

          <section class="surface rounded-lg p-5">
            <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
              <div>
                <p class="eyebrow">Catalogue</p>
                <h3 class="mt-2 font-display text-2xl font-black uppercase text-white">Current releases</h3>
              </div>
              <div class="grid w-full gap-3 md:max-w-2xl md:grid-cols-[1fr_auto]">
                <label>
                  <span class="field-label">Search releases</span>
                  <input class="field-control" data-admin-release-search type="search" placeholder="Search MBP185, artist or track title" />
                </label>
                <label>
                  <span class="field-label">Region</span>
                  <select class="field-control min-w-44" data-admin-release-region>
                    <option value="all">All MBP</option>
                    <option value="europe">MBP Europe</option>
                    <option value="america">MBP America</option>
                    <option value="asia">MBP Asia</option>
                    <option value="world">MBP World</option>
                    <option value="australia">MBP Australia</option>
                  </select>
                </label>
              </div>
            </div>
            <div class="mt-5 grid gap-4 lg:grid-cols-2" data-releases-list></div>
          </section>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // @ts-nocheck
  const loginForm = document.querySelector("[data-login-form]");
  const dashboard = document.querySelector("[data-dashboard]");
  const loginStatus = document.querySelector("[data-login-status]");
  const statsEl = document.querySelector("[data-stats]");
  const artistsList = document.querySelector("[data-artists-list]");
  const releasesList = document.querySelector("[data-releases-list]");
  const submissionsList = document.querySelector("[data-submissions-list]");
  const newsList = document.querySelector("[data-news-list]");
  const artistSelect = document.querySelector("[data-artist-select]");
  const importStatus = document.querySelector("[data-import-status]");
  const artistForm = document.querySelector("[data-artist-form]");
  const artistFormTitle = document.querySelector("[data-artist-form-title]");
  const artistSubmit = document.querySelector("[data-artist-submit]");
  const artistCancel = document.querySelector("[data-artist-cancel]");
  const releaseForm = document.querySelector("[data-release-form]");
  const releaseFormTitle = document.querySelector("[data-release-form-title]");
  const releaseSubmit = document.querySelector("[data-release-submit]");
  const releaseCancel = document.querySelector("[data-release-cancel]");
  const newsForm = document.querySelector("[data-news-form]");
  const newsFormTitle = document.querySelector("[data-news-form-title]");
  const newsSubmit = document.querySelector("[data-news-submit]");
  const newsCancel = document.querySelector("[data-news-cancel]");
  const adminArtistSearch = document.querySelector("[data-admin-artist-search]");
  const adminReleaseSearch = document.querySelector("[data-admin-release-search]");
  const adminArtistRegion = document.querySelector("[data-admin-artist-region]");
  const adminReleaseRegion = document.querySelector("[data-admin-release-region]");
  let artists = [];
  let releases = [];
  let submissions = [];
  let newsArticles = [];
  let artistSearchTerm = "";
  let releaseSearchTerm = "";
  let artistRegionTerm = "all";
  let releaseRegionTerm = "all";
  let submissionCounts = { pending: 0, archived: 0, total: 0 };
  const pages = { artists: 1, releases: 1, submissions: 1, news: 1 };
  const pageSizes = { artists: 10, releases: 8, submissions: 5, news: 6 };
  const mbpRegions = {
    europe: { label: "MBP Europe", color: "#ffd000" },
    america: { label: "MBP America", color: "#23df1e" },
    asia: { label: "MBP Asia", color: "#ff1808" },
    world: { label: "MBP World", color: "#bd00ff" },
    australia: { label: "MBP Australia", color: "#1d27ff" }
  };

  const escapeHtml = (value) =>
    String(value ?? "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#39;");

  const managementAdmins = new Set(["romee storm", "alexair", "rodrigo stadt"]);

  function formatFileSize(value) {
    const size = Number(value || 0);
    if (!size) return "";
    if (size < 1024 * 1024) return `${Math.round(size / 1024)} KB`;
    return `${(size / (1024 * 1024)).toFixed(1)} MB`;
  }

  function renderSubmissionMedia(submission) {
    const upload = submission.upload;
    if (upload?.playback_url && upload.is_audio) {
      return `
        <div class="mt-4 rounded-md border border-white/10 bg-black/35 p-3">
          <p class="text-xs font-bold uppercase tracking-[0.14em] text-steel">Uploaded audio ${upload.name ? `| ${escapeHtml(upload.name)}` : ""} ${upload.size ? `| ${escapeHtml(formatFileSize(upload.size))}` : ""}</p>
          <audio class="mt-3 w-full" controls preload="metadata" src="${escapeHtml(upload.playback_url)}"></audio>
        </div>
      `;
    }

    if (submission.streaming_link) {
      return `
        <div class="mt-4 rounded-md border border-white/10 bg-black/35 p-3">
          <p class="text-xs font-bold uppercase tracking-[0.14em] text-steel">Private streaming link${upload?.name ? ` | uploaded file: ${escapeHtml(upload.name)}` : ""}</p>
          <a class="mt-2 inline-flex rounded border border-white/10 px-3 py-2 text-xs font-bold uppercase text-haze hover:border-neon-cyan hover:text-white" href="${escapeHtml(submission.streaming_link)}" target="_blank" rel="noreferrer">Open private stream</a>
        </div>
      `;
    }

    if (upload?.name) {
      return `
        <div class="mt-4 rounded-md border border-white/10 bg-black/35 p-3">
          <p class="text-xs font-bold uppercase tracking-[0.14em] text-steel">Uploaded file</p>
          <p class="mt-2 text-sm text-haze">${escapeHtml(upload.name)}${upload.size ? ` | ${escapeHtml(formatFileSize(upload.size))}` : ""}</p>
          <p class="mt-1 text-xs text-steel">No audio player is shown because this upload is not an audio file.</p>
        </div>
      `;
    }

    return "";
  }

  async function api(path, options = {}) {
    const response = await fetch(path, {
      credentials: "same-origin",
      ...options,
      headers: {
        "content-type": "application/json",
        ...(options.headers ?? {})
      }
    });
    const data = await response.json().catch(() => ({ ok: false, error: "Invalid API response." }));
    if (!response.ok || data.ok === false) {
      throw new Error(data.error || `Request failed: ${response.status}`);
    }
    return data;
  }

  function dispatchAuth(role = "admin") {
    window.dispatchEvent(new CustomEvent("mbp-auth-changed", { detail: { authenticated: true, role } }));
  }

  function pageItems(items, kind) {
    const totalPages = Math.max(1, Math.ceil(items.length / pageSizes[kind]));
    pages[kind] = Math.min(Math.max(1, pages[kind]), totalPages);
    const start = (pages[kind] - 1) * pageSizes[kind];
    return items.slice(start, start + pageSizes[kind]);
  }

  function renderPager(kind, total) {
    const totalPages = Math.max(1, Math.ceil(total / pageSizes[kind]));
    if (totalPages <= 1) return "";
    const start = (pages[kind] - 1) * pageSizes[kind] + 1;
    const end = Math.min(total, pages[kind] * pageSizes[kind]);
    return `
      <div class="mt-5 flex flex-col gap-3 rounded-md border border-white/10 bg-black/30 p-3 sm:flex-row sm:items-center sm:justify-between">
        <p class="text-xs uppercase tracking-[0.14em] text-steel">Showing ${start}-${end} of ${total}</p>
        <div class="flex gap-2">
          <button class="rounded border border-white/10 px-3 py-2 text-xs font-bold uppercase text-haze disabled:opacity-40" data-page-kind="${kind}" data-page-dir="-1" ${pages[kind] <= 1 ? "disabled" : ""} type="button">Previous</button>
          <span class="rounded border border-white/10 px-3 py-2 text-xs font-bold uppercase text-white">${pages[kind]} / ${totalPages}</span>
          <button class="rounded border border-white/10 px-3 py-2 text-xs font-bold uppercase text-haze disabled:opacity-40" data-page-kind="${kind}" data-page-dir="1" ${pages[kind] >= totalPages ? "disabled" : ""} type="button">Next</button>
        </div>
      </div>
    `;
  }

  function parseLinks(value) {
    return String(value ?? "")
      .split("\n")
      .map((line) => line.trim())
      .filter(Boolean)
      .map((line) => {
        const [label, url] = line.split("|").map((item) => item.trim());
        return { label, url };
      })
      .filter((link) => link.label && link.url);
  }

  function parsePlatformLinks(value) {
    return String(value ?? "")
      .split("\n")
      .map((line) => line.trim())
      .filter(Boolean)
      .map((line) => {
        const [platform, label, url] = line.split("|").map((item) => item.trim());
        return { platform, label: label || platform, url, is_playable: true };
      })
      .filter((link) => link.platform && link.url);
  }

  function linksToText(links) {
    return Array.isArray(links) ? links.map((link) => `${link.label || ""}|${link.url || ""}`).join("\n") : "";
  }

  function searchableText(values) {
    return values.filter(Boolean).join(" ").toLowerCase();
  }

  function regionMeta(region) {
    return mbpRegions[String(region || "").toLowerCase()] || mbpRegions.world;
  }

  function formatAdminDate(value) {
    if (!value) return "No date";
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return String(value);
    return date.toLocaleDateString("en", { year: "numeric", month: "short", day: "numeric" });
  }

  function newsAccent(value) {
    return /^#[0-9a-f]{6}$/i.test(String(value || "")) ? String(value) : "#bd00ff";
  }

  function renderRegionBadge(region) {
    const meta = regionMeta(region);
    return `<span class="inline-flex rounded border px-2 py-1 text-[0.68rem] font-black uppercase tracking-[0.14em]" style="border-color:${escapeHtml(meta.color)}66; color:${escapeHtml(meta.color)}">${escapeHtml(meta.label)}</span>`;
  }

  function filteredArtists() {
    const query = artistSearchTerm.trim().toLowerCase();
    const region = artistRegionTerm;
    return artists.filter((artist) =>
      (region === "all" || String(artist.mbp_region || "world").toLowerCase() === region) &&
      (!query || searchableText([artist.name, artist.country, artist.profile, artist.claimed_email, artist.claimed_role, artist.mbp_region, regionMeta(artist.mbp_region).label]).includes(query))
    );
  }

  function filteredReleases() {
    const query = releaseSearchTerm.trim().toLowerCase();
    const region = releaseRegionTerm;
    return releases.filter((release) =>
      (region === "all" || String(release.mbp_region || "world").toLowerCase() === region) &&
      (!query || searchableText([release.catalog_number, release.title, release.artist_display, release.status, release.genre, release.description, release.mbp_region, regionMeta(release.mbp_region).label]).includes(query))
    );
  }

  function resetArtistEditor() {
    if (!(artistForm instanceof HTMLFormElement)) return;
    artistForm.reset();
    artistForm.removeAttribute("data-editing-artist");
    if (artistFormTitle) artistFormTitle.textContent = "Add artist profile";
    if (artistSubmit) artistSubmit.textContent = "Save artist";
    artistCancel?.setAttribute("hidden", "");
  }

  function startArtistEditor(artist) {
    if (!(artistForm instanceof HTMLFormElement)) return;
    artistForm.setAttribute("data-editing-artist", artist.id);
    artistForm.elements.name.value = artist.name || "";
    artistForm.elements.country.value = artist.country || "";
    artistForm.elements.mbp_region.value = artist.mbp_region || "world";
    artistForm.elements.profile.value = artist.profile || "";
    artistForm.elements.image_url.value = artist.image_url || "";
    artistForm.elements.links.value = linksToText(artist.links || []);
    artistForm.elements.is_featured.checked = Boolean(artist.is_featured);
    if (artistFormTitle) artistFormTitle.textContent = `Edit ${artist.name}`;
    if (artistSubmit) artistSubmit.textContent = "Update artist";
    artistCancel?.removeAttribute("hidden");
    artistForm.scrollIntoView({ behavior: "smooth", block: "start" });
