---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Artist Dashboard" description="Edit your The MasterBeat Project artist profile." noindex={true}>
  <section class="border-b border-white/10 bg-black/50 py-16">
    <div class="section-shell">
      <p class="eyebrow">Artist portal</p>
      <h1 class="page-title mt-4">Artist dashboard</h1>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-haze">
        Login is available for artists and admins after their MBP artist profile has been claimed from a private invitation link.
      </p>
    </div>
  </section>

  <section class="py-14">
    <div class="section-shell">
      <div data-artist-app>
        <form data-artist-login class="surface mx-auto grid max-w-xl gap-4 rounded-lg p-6">
          <p class="eyebrow">Login</p>
          <label>
            <span class="field-label">Email</span>
            <input class="field-control" name="email" type="email" required autocomplete="email" />
          </label>
          <label>
            <span class="field-label">Password</span>
            <input class="field-control" name="password" type="password" required autocomplete="current-password" />
          </label>
          <button class="rounded-md bg-white px-5 py-3 text-sm font-black uppercase tracking-[0.14em] text-black hover:bg-neon-cyan" type="submit">
            Login
          </button>
          <button class="justify-self-start text-sm font-bold text-neon-cyan hover:text-white" type="button" data-forgot-toggle>
            Forgot password?
          </button>
          <p class="text-sm text-steel" data-login-status>Use the login created from your artist claim invitation.</p>
        </form>

        <form data-forgot-form hidden class="surface mx-auto grid max-w-xl gap-4 rounded-lg p-6">
          <p class="eyebrow">Password reset</p>
          <p class="text-sm leading-6 text-steel">Enter the email used when you claimed your MBP artist profile. Reset links are sent only for claimed artist accounts.</p>
          <label>
            <span class="field-label">Email</span>
            <input class="field-control" name="email" type="email" required autocomplete="email" />
          </label>
          <div class="flex flex-wrap gap-3">
            <button class="rounded-md bg-white px-5 py-3 text-sm font-black uppercase tracking-[0.14em] text-black hover:bg-neon-cyan" type="submit">
              Send reset link
            </button>
            <button class="rounded-md border border-white/10 px-5 py-3 text-sm font-bold uppercase tracking-[0.12em] text-haze hover:border-neon-cyan hover:text-white" type="button" data-forgot-cancel>
              Back to login
            </button>
          </div>
          <p class="text-sm text-steel" data-forgot-status></p>
        </form>

        <form data-reset-form hidden class="surface mx-auto grid max-w-xl gap-4 rounded-lg p-6">
          <p class="eyebrow">Set new password</p>
          <input name="token" type="hidden" />
          <label>
            <span class="field-label">New password</span>
            <input class="field-control" name="password" type="password" minlength="8" required autocomplete="new-password" />
          </label>
          <button class="rounded-md bg-white px-5 py-3 text-sm font-black uppercase tracking-[0.14em] text-black hover:bg-neon-cyan" type="submit">
            Reset password
          </button>
          <p class="text-sm text-steel" data-reset-status></p>
        </form>

        <div data-profile-panel hidden class="surface mx-auto max-w-3xl rounded-lg p-6">
          <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
            <div>
              <p class="eyebrow">Profile editor</p>
              <h2 class="mt-2 font-display text-3xl font-black uppercase text-white" data-profile-title>Artist profile</h2>
            </div>
            <button data-logout class="rounded-md border border-white/10 px-4 py-2 text-sm font-bold text-haze hover:border-neon-cyan hover:text-white" type="button">
              Logout
            </button>
          </div>
          <form data-profile-form class="mt-6 grid gap-4">
            <input name="artist_id" type="hidden" />
            <label>
              <span class="field-label">Artist name</span>
              <input class="field-control" name="name" required />
            </label>
            <label>
              <span class="field-label">Country / role</span>
              <input class="field-control" name="country" />
            </label>
            <label>
              <span class="field-label">Public profile</span>
              <textarea class="field-control min-h-36" name="profile"></textarea>
            </label>
            <label>
              <span class="field-label">Image URL</span>
              <input class="field-control" name="image_url" type="text" inputmode="url" />
            </label>
            <label>
              <span class="field-label">Upload profile image</span>
              <input class="field-control" name="image_upload" type="file" accept="image/*" />
              <span class="mt-2 block text-xs leading-5 text-steel">Choose an image from your computer. It will be uploaded privately to Cloudflare R2 and used as your public profile image.</span>
            </label>
            <fieldset class="rounded-lg border border-white/10 p-4">
              <legend class="px-2 text-sm font-semibold text-haze">Official social links</legend>
              <div class="grid gap-3 sm:grid-cols-2" data-social-fields>
                {[
                  ["spotify", "Spotify"],
                  ["instagram", "Instagram"],
                  ["youtube", "YouTube"],
                  ["facebook", "Facebook"],
                  ["soundcloud", "SoundCloud"],
                  ["tiktok", "TikTok"],
                  ["x", "X / Twitter"],
                  ["threads", "Threads"],
                  ["apple_music", "Apple Music"],
                  ["beatport", "Beatport"],
                  ["bandcamp", "Bandcamp"],
                  ["audiomack", "Audiomack"],
                  ["linktree", "Linktree"],
                  ["website", "Website"]
                ].map(([key, label]) => (
                  <label>
                    <span class="field-label">{label}</span>
                    <input class="field-control" name={`link_${key}`} type="url" inputmode="url" placeholder={`https://`} />
                  </label>
                ))}
              </div>
            </fieldset>
            <div class="flex flex-wrap items-center gap-3">
              <button class="rounded-md bg-white px-5 py-3 text-sm font-black uppercase tracking-[0.14em] text-black hover:bg-neon-cyan" type="submit">
                Save profile
              </button>
              <a data-public-profile class="rounded-md border border-white/10 px-5 py-3 text-sm font-bold uppercase tracking-[0.12em] text-haze hover:border-neon-cyan hover:text-white" href="/artists/">
                View public profile
              </a>
            </div>
            <p class="text-sm text-steel" data-profile-status></p>
          </form>

          <section class="mt-8 border-t border-white/10 pt-6">
            <div>
              <p class="eyebrow">Release calendar</p>
              <h3 class="mt-2 font-display text-2xl font-black uppercase text-white">Open label slots</h3>
              <p class="mt-2 text-sm leading-6 text-steel">Available MBP, MBH and S7 release windows with agreement, artwork and distributor delivery deadlines.</p>
            </div>
            <div class="mt-4 grid gap-3 sm:grid-cols-2" data-artist-calendar-list></div>
          </section>

          <section class="mt-8 border-t border-white/10 pt-6">
            <div>
              <p class="eyebrow">Release agreements</p>
              <h3 class="mt-2 font-display text-2xl font-black uppercase text-white">Agreement review</h3>
              <p class="mt-2 text-sm leading-6 text-steel">Complete legal details, rights checklist, collaborator splits and typed signature for approved releases.</p>
            </div>
            <div class="mt-4 grid gap-3" data-artist-agreement-list></div>
            <div class="mt-5" data-artist-agreement-detail></div>
          </section>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // @ts-nocheck
  const loginForm = document.querySelector("[data-artist-login]");
  const forgotForm = document.querySelector("[data-forgot-form]");
  const resetForm = document.querySelector("[data-reset-form]");
  const loginStatus = document.querySelector("[data-login-status]");
  const forgotStatus = document.querySelector("[data-forgot-status]");
  const resetStatus = document.querySelector("[data-reset-status]");
  const panel = document.querySelector("[data-profile-panel]");
  const profileForm = document.querySelector("[data-profile-form]");
  const profileStatus = document.querySelector("[data-profile-status]");
  const profileTitle = document.querySelector("[data-profile-title]");
  const publicProfile = document.querySelector("[data-public-profile]");
  const artistCalendarList = document.querySelector("[data-artist-calendar-list]");
  const artistAgreementList = document.querySelector("[data-artist-agreement-list]");
  const artistAgreementDetail = document.querySelector("[data-artist-agreement-detail]");
  const resetToken = new URL(location.href).searchParams.get("reset");
  const requestedAgreementId = new URL(location.href).searchParams.get("agreement");
  let artistCalendarSlots = [];
  let artistAgreements = [];
  let requestedAgreementOpened = false;

  const socialFields = [
    { key: "spotify", label: "Spotify", aliases: ["spotify"] },
    { key: "instagram", label: "Instagram", aliases: ["instagram", "ig"] },
    { key: "youtube", label: "YouTube", aliases: ["youtube", "you tube"] },
    { key: "facebook", label: "Facebook", aliases: ["facebook", "fb"] },
    { key: "soundcloud", label: "SoundCloud", aliases: ["soundcloud", "sound cloud"] },
    { key: "tiktok", label: "TikTok", aliases: ["tiktok", "tik tok"] },
    { key: "x", label: "X / Twitter", aliases: ["x", "twitter", "x / twitter"] },
    { key: "threads", label: "Threads", aliases: ["threads"] },
    { key: "apple_music", label: "Apple Music", aliases: ["apple music", "apple", "itunes"] },
    { key: "beatport", label: "Beatport", aliases: ["beatport"] },
    { key: "bandcamp", label: "Bandcamp", aliases: ["bandcamp"] },
    { key: "audiomack", label: "Audiomack", aliases: ["audiomack"] },
    { key: "linktree", label: "Linktree", aliases: ["linktree"] },
    { key: "website", label: "Website", aliases: ["website", "web", "official", "site"] }
  ];

  function normalizedLabel(value) {
    return String(value || "").trim().toLowerCase().replace(/[_-]+/g, " ");
  }

  function setSocialLinks(links) {
    const list = Array.isArray(links) ? links : [];
    for (const field of socialFields) {
      const input = profileForm?.querySelector(`[name="link_${field.key}"]`);
      if (!(input instanceof HTMLInputElement)) continue;
      const found = list.find((link) => field.aliases.includes(normalizedLabel(link.label)));
      input.value = found?.url || "";
    }
  }

  function collectSocialLinks(formData) {
    return socialFields
      .map((field) => ({
        label: field.label,
        url: String(formData.get(`link_${field.key}`) || "").trim()
      }))
      .filter((link) => link.url);
  }

  function hideElement(element) {
    if (!element) return;
    element.hidden = true;
    element.style.display = "none";
  }

  function showElement(element, display = "") {
    if (!element) return;
    element.hidden = false;
    element.style.display = display;
  }

  function dispatchAuth(role) {
    window.dispatchEvent(new CustomEvent("mbp-auth-changed", { detail: { authenticated: true, role } }));
  }

  async function api(path, options = {}) {
    const response = await fetch(path, {
      credentials: "same-origin",
      ...options,
      headers: { "content-type": "application/json", ...(options.headers || {}) }
    });
    const data = await response.json().catch(() => ({ ok: false, error: "Invalid API response." }));
    if (!response.ok || data.ok === false) throw new Error(data.error || `Request failed: ${response.status}`);
    return data;
  }

  async function uploadProfileImage(artistId, file) {
    const formData = new FormData();
    formData.set("artist_id", artistId);
    formData.set("image", file);
    const response = await fetch("/api/artist/image-upload", {
      method: "POST",
      credentials: "same-origin",
      body: formData
    });
    const data = await response.json().catch(() => ({ ok: false, error: "Invalid upload response." }));
    if (!response.ok || data.ok === false) throw new Error(data.error || `Upload failed: ${response.status}`);
    return data;
  }

  const portalBrandColors = { MBP: "#bd00ff", MBH: "#00e5ff", S7: "#ffd000" };

  function escapeHtml(value) {
    return String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");
  }

  function formatPortalDate(value) {
    if (!value) return "No date";
    const date = new Date(`${String(value).slice(0, 10)}T00:00:00`);
    if (Number.isNaN(date.getTime())) return value;
    return date.toLocaleDateString(undefined, { year: "numeric", month: "short", day: "numeric" });
  }

  function agreementLabel(agreement) {
    const catalog = agreement.slot_catalog_number || agreement.calendar_catalog_number || agreement.id;
    return `${catalog} - ${agreement.release_title || agreement.track_title || "Release agreement"}`;
  }

  function renderArtistCalendar() {
    if (!artistCalendarList) return;
    const slots = artistCalendarSlots
      .filter((slot) => ["available", "reserved"].includes(String(slot.status || "").toLowerCase()))
      .slice(0, 8);
    artistCalendarList.innerHTML = slots.length
      ? slots
          .map((slot) => {
            const color = portalBrandColors[slot.brand] || "#bd00ff";
            return `
              <article class="rounded-md border bg-black/30 p-4" style="border-color:${color}66">
                <div class="flex items-center justify-between gap-3">
                  <p class="font-display text-xl font-black uppercase text-white">${escapeHtml(slot.brand)}</p>
                  <span class="rounded border px-2 py-1 text-[0.7rem] font-black uppercase tracking-[0.16em]" style="border-color:${color};color:${color}">
                    ${escapeHtml(slot.status)}
                  </span>
                </div>
                <p class="mt-2 text-sm text-haze">${formatPortalDate(slot.release_date)}</p>
                <div class="mt-4 grid gap-1 text-xs leading-5 text-steel">
                  <span>Agreement: ${formatPortalDate(slot.agreement_deadline)}</span>
                  <span>Assets: ${formatPortalDate(slot.asset_deadline)}</span>
                  <span>Distributor: ${formatPortalDate(slot.distributor_delivery_deadline)}</span>
                  <span>Promo: ${formatPortalDate(slot.promo_start_date)}</span>
                </div>
              </article>`;
          })
          .join("")
      : `<p class="text-sm text-steel">No open release slots are listed right now.</p>`;
  }

  function renderArtistAgreements() {
    if (!artistAgreementList) return;
    artistAgreementList.innerHTML = artistAgreements.length
      ? artistAgreements
          .map(
            (agreement) => `
              <article class="rounded-md border border-white/10 bg-black/30 p-4">
                <div class="flex flex-wrap items-start justify-between gap-3">
                  <div>
                    <p class="eyebrow">${escapeHtml(agreement.brand || "MBP")} agreement</p>
                    <h4 class="mt-2 font-display text-xl font-black uppercase text-white">${escapeHtml(agreementLabel(agreement))}</h4>
                    <p class="mt-1 text-sm text-steel">${escapeHtml(agreement.status || "waiting_artist_details")} | ${formatPortalDate(agreement.planned_release_date)}</p>
                  </div>
                  <button class="rounded-md border border-white/10 px-4 py-2 text-xs font-black uppercase tracking-[0.14em] text-haze hover:border-neon-cyan hover:text-white" type="button" data-open-agreement="${escapeHtml(agreement.id)}">
                    Open agreement
                  </button>
                </div>
              </article>`
          )
          .join("")
      : `<p class="text-sm text-steel">No release agreements are assigned to this artist account yet.</p>`;
  }

  async function loadPortalData() {
    const [calendarResult, agreementResult] = await Promise.allSettled([
      api("/api/calendar?from=2026-01-01", { method: "GET", headers: {} }),
      api("/api/artist/agreements", { method: "GET", headers: {} })
    ]);
    if (calendarResult.status === "fulfilled") artistCalendarSlots = calendarResult.value.slots || [];
    if (agreementResult.status === "fulfilled") artistAgreements = agreementResult.value.agreements || [];
    renderArtistCalendar();
    renderArtistAgreements();
    if (requestedAgreementId && !requestedAgreementOpened && artistAgreements.some((agreement) => agreement.id === requestedAgreementId)) {
      requestedAgreementOpened = true;
      await loadAgreementDetail(requestedAgreementId);
    }
  }

  async function loadAgreementDetail(agreementId) {
    if (!artistAgreementDetail) return;
    artistAgreementDetail.innerHTML = `<p class="text-sm text-steel">Loading agreement...</p>`;
    try {
      const detail = await api(`/api/artist/agreements/${agreementId}`, { method: "GET", headers: {} });
      renderAgreementDetail(detail);
    } catch (error) {
      artistAgreementDetail.innerHTML = `<p class="text-sm text-red-300">${escapeHtml(error.message)}</p>`;
    }
  }

  function renderAgreementDetail(detail) {
    if (!artistAgreementDetail) return;
    const agreement = detail.agreement || {};
    const parties = detail.parties || [];
    const splits = detail.splits || [];
    const checklist = detail.checklist || [];
    const signatures = detail.signatures || [];
    const artistParty = parties.find((party) => party.role === "artist") || {};
    const splitsText =
      splits.length > 0
        ? splits.map((split) => `${split.payee_name || ""}|${split.role || "artist"}|${split.email || ""}|${split.share_of_artist_pool ?? 0}`).join("\n")
        : `${agreement.artist_name || ""}|artist|${agreement.artist_email || ""}|100`;
    const canSign = !["completed", "cancelled"].includes(String(agreement.status || "").toLowerCase());
    artistAgreementDetail.innerHTML = `
      <div class="rounded-md border border-white/10 bg-black/30 p-5">
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div>
            <p class="eyebrow">${escapeHtml(agreement.brand || "MBP")} release agreement</p>
            <h4 class="mt-2 font-display text-2xl font-black uppercase text-white">${escapeHtml(agreement.release_title || "Agreement")}</h4>
            <p class="mt-1 text-sm text-steel">${escapeHtml(agreement.status || "waiting_artist_details")} | ${formatPortalDate(agreement.planned_release_date)}</p>
          </div>
        </div>
        <form class="mt-5 grid gap-4" data-agreement-detail-form="${escapeHtml(agreement.id)}">
          <div class="grid gap-4 md:grid-cols-2">
            <label>
              <span class="field-label">Release title</span>
              <input class="field-control" name="release_title" value="${escapeHtml(agreement.release_title || "")}" required />
            </label>
            <label>
              <span class="field-label">Genre</span>
              <input class="field-control" name="genre" value="${escapeHtml(agreement.genre || "")}" />
            </label>
            <label>
              <span class="field-label">Legal name</span>
              <input class="field-control" name="legal_name" value="${escapeHtml(artistParty.legal_name || "")}" required />
            </label>
            <label>
              <span class="field-label">Payment email</span>
              <input class="field-control" name="payment_email" type="email" value="${escapeHtml(artistParty.payment_email || artistParty.email || "")}" />
            </label>
            <label>
              <span class="field-label">SplitShare email</span>
              <input class="field-control" name="splitshare_email" type="email" value="${escapeHtml(artistParty.splitshare_email || artistParty.email || "")}" />
            </label>
            <label>
              <span class="field-label">Country</span>
              <input class="field-control" name="country" value="${escapeHtml(artistParty.country || "")}" required />
            </label>
          </div>
          <div class="grid gap-4 md:grid-cols-2">
            <label>
              <span class="field-label">Street address</span>
              <input class="field-control" name="street_address" value="${escapeHtml(artistParty.street_address || "")}" />
            </label>
            <label>
              <span class="field-label">City</span>
              <input class="field-control" name="city" value="${escapeHtml(artistParty.city || "")}" />
            </label>
            <label>
              <span class="field-label">State / province</span>
              <input class="field-control" name="state_province" value="${escapeHtml(artistParty.state_province || "")}" />
            </label>
            <label>
              <span class="field-label">Postal code</span>
              <input class="field-control" name="postal_code" value="${escapeHtml(artistParty.postal_code || "")}" />
            </label>
          </div>
          <label>
            <span class="field-label">Collaborators and splits, one per line: name|role|email|share of artist pool</span>
            <textarea class="field-control min-h-32" name="splits_text">${escapeHtml(splitsText)}</textarea>
          </label>
          <fieldset class="rounded-md border border-white/10 p-4">
            <legend class="field-label px-2">Rights checklist</legend>
            <div class="grid gap-3">
              ${checklist
                .map(
                  (item) => `
                    <label class="flex gap-3 text-sm leading-6 text-haze">
                      <input class="mt-1 h-4 w-4 accent-neon-cyan" type="checkbox" name="checklist" value="${escapeHtml(item.item_key)}" ${item.status === "confirmed" ? "checked" : ""} />
                      <span>${escapeHtml(item.label)}</span>
                    </label>`
                )
                .join("")}
            </div>
          </fieldset>
          <div class="flex flex-wrap items-center gap-3">
            <button class="rounded-md bg-white px-5 py-3 text-sm font-black uppercase tracking-[0.14em] text-black hover:bg-neon-cyan" type="submit">Save agreement details</button>
            <span class="text-sm text-steel" data-agreement-save-status></span>
          </div>
        </form>
        ${
          canSign
            ? `<form class="mt-6 grid gap-3 border-t border-white/10 pt-5" data-agreement-sign-form="${escapeHtml(agreement.id)}">
                <label>
                  <span class="field-label">Typed artist signature</span>
                  <input class="field-control" name="signature_text" placeholder="Type your legal name to sign" required />
                </label>
                <div class="flex flex-wrap items-center gap-3">
                  <button class="rounded-md border border-neon-cyan px-5 py-3 text-sm font-black uppercase tracking-[0.14em] text-neon-cyan hover:bg-neon-cyan hover:text-black" type="submit">Sign agreement</button>
                  <span class="text-sm text-steel" data-agreement-sign-status></span>
                </div>
              </form>`
            : ""
        }
        <div class="mt-5 text-xs leading-6 text-steel">
          ${signatures.length ? `Signatures: ${signatures.map((signature) => escapeHtml(signature.signer_name || signature.signer_email)).join(", ")}` : "No signatures yet."}
        </div>
      </div>`;
  }

  async function loadProfile() {
    const data = await api("/api/artist/profile", { method: "GET", headers: {} });
    if (!data.artist) throw new Error("No artist profile is linked to this account yet.");
    const artist = data.artist;
    hideElement(loginForm);
    hideElement(forgotForm);
    hideElement(resetForm);
    showElement(panel);
    profileTitle.textContent = artist.name;
    profileForm.artist_id.value = artist.id;
    profileForm.name.value = artist.name || "";
    profileForm.country.value = artist.country || "";
    profileForm.profile.value = artist.profile || "";
    profileForm.image_url.value = artist.image_url || "";
    profileForm.image_upload.value = "";
    setSocialLinks(artist.links);
    publicProfile.href = `/artist/${artist.slug}`;
    await loadPortalData();
  }

  loginForm?.addEventListener("submit", async (event) => {
    event.preventDefault();
    const formData = new FormData(loginForm);
    loginStatus.textContent = "Logging in...";
    try {
      const result = await api("/api/auth/login", {
        method: "POST",
        body: JSON.stringify({ email: formData.get("email"), password: formData.get("password") })
      });
      dispatchAuth(result.role === "admin" ? "admin" : result.role || "artist");
      await loadProfile();
      loginStatus.textContent = "Logged in.";
    } catch (error) {
      loginStatus.textContent = error.message;
    }
  });

  profileForm?.addEventListener("submit", async (event) => {
    event.preventDefault();
    const formData = new FormData(profileForm);
    profileStatus.textContent = "Saving...";
    try {
      let imageUrl = formData.get("image_url");
      const imageFile = formData.get("image_upload");
      if (imageFile instanceof File && imageFile.size > 0) {
        profileStatus.textContent = "Uploading image...";
        const upload = await uploadProfileImage(formData.get("artist_id"), imageFile);
        imageUrl = upload.url;
        profileForm.image_url.value = upload.url;
      }
      await api("/api/artist/profile", {
        method: "PUT",
        body: JSON.stringify({
          artist_id: formData.get("artist_id"),
          name: formData.get("name"),
          country: formData.get("country"),
          profile: formData.get("profile"),
          image_url: imageUrl,
          links: collectSocialLinks(formData)
        })
      });
      profileStatus.textContent = "Profile saved.";
      await loadProfile();
    } catch (error) {
      profileStatus.textContent = error.message;
    }
  });

  document.querySelector("[data-forgot-toggle]")?.addEventListener("click", () => {
    const emailInput = loginForm?.querySelector('input[name="email"]');
    const forgotEmail = forgotForm?.querySelector('input[name="email"]');
    if (emailInput instanceof HTMLInputElement && forgotEmail instanceof HTMLInputElement) {
      forgotEmail.value = emailInput.value;
    }
    hideElement(loginForm);
    hideElement(panel);
    showElement(forgotForm, "grid");
  });

  document.querySelector("[data-forgot-cancel]")?.addEventListener("click", () => {
    hideElement(forgotForm);
    showElement(loginForm, "grid");
  });

  forgotForm?.addEventListener("submit", async (event) => {
    event.preventDefault();
    const formData = new FormData(forgotForm);
    forgotStatus.textContent = "Sending reset link...";
    try {
      const result = await api("/api/auth/forgot-password", {
        method: "POST",
        body: JSON.stringify({ email: formData.get("email") })
      });
      forgotStatus.textContent =
        result.email?.status === "account_not_claimed"
          ? "No claimed artist account exists for this email."
          : "If the email belongs to a claimed artist account, a reset link has been sent.";
    } catch (error) {
      forgotStatus.textContent = error.message;
    }
  });

  resetForm?.addEventListener("submit", async (event) => {
    event.preventDefault();
    const formData = new FormData(resetForm);
    resetStatus.textContent = "Resetting password...";
    try {
      const result = await api("/api/auth/reset-password", {
        method: "POST",
        body: JSON.stringify({ token: formData.get("token"), password: formData.get("password") })
      });
      dispatchAuth(result.role || "artist");
      resetStatus.textContent = "Password reset. Opening your dashboard...";
      await loadProfile();
    } catch (error) {
      resetStatus.textContent = error.message;
    }
  });

  document.addEventListener("click", (event) => {
    if (!(event.target instanceof Element)) return;
    const openAgreement = event.target.closest("[data-open-agreement]");
    if (openAgreement) {
      loadAgreementDetail(openAgreement.getAttribute("data-open-agreement"));
    }
  });

  document.addEventListener("submit", async (event) => {
    if (!(event.target instanceof HTMLFormElement)) return;

    const detailsForm = event.target.closest("[data-agreement-detail-form]");
    if (detailsForm instanceof HTMLFormElement) {
      event.preventDefault();
      const agreementId = detailsForm.getAttribute("data-agreement-detail-form");
      const status = detailsForm.querySelector("[data-agreement-save-status]");
      const formData = new FormData(detailsForm);
      const checklist = Array.from(detailsForm.querySelectorAll('input[name="checklist"]:checked')).map((input) => input.value);
      if (status) status.textContent = "Saving agreement...";
      try {
        const result = await api(`/api/artist/agreements/${agreementId}`, {
          method: "POST",
          body: JSON.stringify({
            action: "save_details",
            release_title: formData.get("release_title"),
            genre: formData.get("genre"),
            legal_name: formData.get("legal_name"),
            payment_email: formData.get("payment_email"),
            splitshare_email: formData.get("splitshare_email"),
            street_address: formData.get("street_address"),
            city: formData.get("city"),
            state_province: formData.get("state_province"),
            postal_code: formData.get("postal_code"),
            country: formData.get("country"),
            splits_text: formData.get("splits_text"),
            checklist
          })
        });
        if (status) status.textContent = "Agreement details saved.";
        if (result.detail) renderAgreementDetail(result.detail);
        await loadPortalData();
      } catch (error) {
        if (status) status.textContent = error.message;
      }
      return;
    }

    const signForm = event.target.closest("[data-agreement-sign-form]");
    if (signForm instanceof HTMLFormElement) {
      event.preventDefault();
      const agreementId = signForm.getAttribute("data-agreement-sign-form");
      const status = signForm.querySelector("[data-agreement-sign-status]");
      const formData = new FormData(signForm);
      if (status) status.textContent = "Signing agreement...";
      try {
        const result = await api(`/api/artist/agreements/${agreementId}`, {
          method: "POST",
          body: JSON.stringify({
            action: "sign_artist",
            signature_text: formData.get("signature_text")
          })
        });
        if (status) status.textContent = "Agreement signed. Label signature is next.";
        if (result.detail) renderAgreementDetail(result.detail);
        await loadPortalData();
      } catch (error) {
        if (status) status.textContent = error.message;
      }
    }
  });

  document.querySelector("[data-logout]")?.addEventListener("click", async () => {
    await api("/api/auth/logout", { method: "POST", body: "{}" });
    location.reload();
  });

  api("/api/auth/me", { method: "GET", headers: {} })
    .then((session) => {
      if (session.authenticated) {
        const role = session.session?.role || "artist";
        dispatchAuth(role);
        return loadProfile();
      }
      if (resetToken && resetForm instanceof HTMLFormElement) {
        const tokenField = resetForm.querySelector('input[name="token"]');
        if (tokenField instanceof HTMLInputElement) tokenField.value = resetToken;
        hideElement(loginForm);
        hideElement(forgotForm);
        showElement(resetForm, "grid");
        hideElement(panel);
        return;
      }
      showElement(loginForm, "grid");
      hideElement(panel);
    })
    .catch(() => {
      if (resetToken && resetForm instanceof HTMLFormElement) {
        const tokenField = resetForm.querySelector('input[name="token"]');
        if (tokenField instanceof HTMLInputElement) tokenField.value = resetToken;
        hideElement(loginForm);
        hideElement(forgotForm);
        showElement(resetForm, "grid");
        hideElement(panel);
        return;
      }
      showElement(loginForm, "grid");
      hideElement(panel);
    });
</script>
